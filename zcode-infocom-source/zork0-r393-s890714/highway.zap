	ZERO?	STACK /?CCL20
	SET	'J-DISCARD-FROMP-PROB,0
	SET	'PLAY-NUM,1
	SET	'SUIT,FROMP-SUIT
	SET	'RANK,TREBLED-RANK
	JUMP	?CND18
?CCL20:	RANDOM	12 >PLAY-NUM
	RANDOM	15 >SUIT
	CALL2	PROB,PICTURE-CARD-PROB
	ZERO?	STACK /?CCL23
	RANDOM	9
	ADD	11,STACK >RANK
	JUMP	?CND18
?CCL23:	RANDOM	11 >RANK
?CND18:	PUT	J-LAST-CARD,0,RANK
	PUT	J-LAST-CARD,1,SUIT
	MUL	PLAY-NUM,SUIT
	MUL	STACK,RANK
	MOD	STACK,17 >NUM
	EQUAL?	PLAY-NUM,1 \?CND24
	FCLEAR	NOT-HERE-OBJECT,DRAW-CARDS-OFFSET
	PUTB	F-CARD-TABLE,0,RANK
	PUTB	F-CARD-TABLE,1,SUIT
