	GET	PICINF-TBL,1 >?TMP2
	MUL	FONT-X,16
	ADD	?TMP2,STACK
	CURSET	?TMP1,STACK
	LESS?	J-SCORE,10 \?CCL3
	PRINTI	" 00"
	JUMP	?CND1
?CCL3:	LESS?	J-SCORE,100 \?CCL5
	PRINTI	" 0"
	JUMP	?CND1
?CCL5:	LESS?	J-SCORE,1000 \?CND1
	PRINTC	32
?CND1:	PRINTN	J-SCORE
	GET	PICINF-TBL,0 >?TMP1
	WINGET	S-WINDOW,WWIDE >?TMP3
	GET	PICINF-TBL,1
	SUB	?TMP3,STACK >?TMP2
