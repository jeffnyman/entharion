	MOVE	JESTER,HERE
	ICALL2	DEQUEUE,I-JESTER
	ICALL2	THIS-IS-IT,JESTER
	ICALL1	RETURN-FROM-MAP
	PRINTI	"   You do a "
	SUB	MOVES,J-DISPOSED
	LESS?	STACK,4 \?CCL12
	PRINTI	"triple"
	JUMP	?CND10
?CCL12:	PRINTI	"double"
?CND10:	PRINTR	" take as you notice the jester at the card table, grandly shuffling a thick deck. ""I don't wear any Gucci, I can't dance the hootchy-kootchy, I've never been good at the old smoochie-woochie, but I sure am a whiz at Double Fanucci! When I start to deal, the tension is real; if you can stand the heat, pull up a seat!"" He motions for you to sit down at the table."


	.FUNCT	DOUBLE-FANUCCI-F:ANY:0:0
	EQUAL?	PRSA,V?PLAY \FALSE
	EQUAL?	HERE,CASINO \?CCL6
	IN?	JESTER,HERE \?CCL6
	IN?	BROOM,LOCAL-GLOBALS \?CCL6
	LOC	PROTAGONIST
	EQUAL?	STACK,CARD-TABLE \?CCL12
	ICALL1	F-START
	RTRUE	
?CCL12:	ICALL	PERFORM,V?ENTER,CARD-TABLE
	RTRUE	
?CCL6:	PRINTR	"You don't have a pack of Fanucci cards; besides, there's no solitaire version of Double Fanucci."


	.FUNCT	CARD-TABLE-F:ANY:0:1,VARG
	EQUAL?	VARG,M-ENTER \?CCL3
	IN?	BROOM,LOCAL-GLOBALS \?CCL3
