?CND57:	ICALL	BOLD-MOVE,X,Y,PTR
	JUMP	?PRG1
?CCL54:	EQUAL?	KEY,10,13 \?CCL61
	CALL2	PLAY-SELECTED,PTR
	EQUAL?	STACK,TRUE-VALUE /TRUE
	ICALL	UNBOLD-MOVE,X,Y,PTR
	RFALSE	
?CCL61:	CLEAR	S-TEXT
	SOUND	1
	PRINTI	"Use the arrow keys to highlight a play, or hit RETURN/ENTER to select the currently highlighted play."
	ICALL1	2CR-TO-PRINTER
	JUMP	?PRG1


	.FUNCT	UNBOLD-MOVE:ANY:3:3,X,Y,PTR
	SCREEN	S-WINDOW
	CURSET	Y,X
	PRINTC	32
	CALL1	APPLE?
	ZERO?	STACK /?CCL3
	GET	F-PLAY-TABLE-APPLE,PTR
	JUMP	?CND1
?CCL3:	GET	F-PLAY-TABLE,PTR
?CND1:	PRINT	STACK
	SCREEN	S-TEXT
	RTRUE	


	.FUNCT	BOLD-MOVE:ANY:3:3,X,Y,PTR
	SCREEN	S-WINDOW
	CURSET	Y,X
	HLIGHT	H-BOLD
	PRINTC	62
	CALL1	APPLE?
	ZERO?	STACK /?CCL3
	GET	F-PLAY-TABLE-APPLE,PTR
	JUMP	?CND1
?CCL3:	GET	F-PLAY-TABLE,PTR
?CND1:	PRINT	STACK
	HLIGHT	H-NORMAL
	SCREEN	S-TEXT
	RTRUE	


	.FUNCT	PLAY-SELECTED:ANY:1:1,PTR,CNT,X,NUM,?TMP1
	EQUAL?	PTR,14 /TRUE
	EQUAL?	PTR,13 \?CCL5
	SET	'F-WIN-COUNT,0
	CALL2	PROB,50
	ZERO?	STACK /?CCL8
	ICALL2	CHEAT-RESULT,CHEAT-WINS
	RFALSE	
?CCL8:	ICALL2	CHEAT-RESULT,CHEAT-LOSSES
	RFALSE	
?CCL5:	ZERO?	PTR \?CCL10
	SET	'F-WIN-COUNT,0
	SET	'CNT,0
?PRG11:	GETB	F-CARD-TABLE,CNT
	ZERO?	STACK \?CCL15
	DIV	CNT,2
	ADD	STACK,DRAW-CARDS-OFFSET
	FCLEAR	NOT-HERE-OBJECT,STACK
	ICALL2	PICK-RANK,CNT
	ADD	CNT,1 >?TMP1
	RANDOM	15
	PUTB	F-CARD-TABLE,?TMP1,STACK
	CLEAR	S-TEXT
	PRINTI	"You draw "
	ICALL2	PRINT-CARD-NAME,CNT
	PRINTC	46
	RFALSE	
?CCL15:	EQUAL?	CNT,8 \?CND13
	CLEAR	S-TEXT
	PRINTI	"The jester snickers. ""You've no empty slot; you forfeit your shot!"""
	ICALL1	2CR-TO-PRINTER
	RFALSE	
?CND13:	ADD	CNT,2 >CNT
	JUMP	?PRG11
?CCL10:	GETB	F-CARD-TABLE,2
	ZERO?	STACK \?CCL18
	GETB	F-CARD-TABLE,4
	ZERO?	STACK \?CCL18
	GETB	F-CARD-TABLE,6
	ZERO?	STACK \?CCL18
	GETB	F-CARD-TABLE,8
	ZERO?	STACK \?CCL18
	CLEAR	S-TEXT
	SOUND	1
	PRINTI	"You can't "
	GET	F-PLAY-TABLE-LC,PTR
	PRINT	STACK
	PRINTI	" just now; you have no drawn cards!"
	ICALL1	2CR-TO-PRINTER
	RFALSE	
?CCL18:	CLEAR	S-TEXT
	PRINTI	"Use your mouse"
	CALL1	APPLE?
	ZERO?	STACK \?CCL24
	GETB	0,30
	EQUAL?	STACK,IBM \?CND23
?CCL24:	PRINTI	"/joystick"
?CND23:	PRINTI	" or type the number of the card you'd like to "
	GET	F-PLAY-TABLE-LC,PTR
	PRINT	STACK
	PRINTC	46
	ICALL1	2CR-TO-PRINTER
?PRG27:	INPUT	1 >X
	ICALL1	MOUSE-INPUT?
	CLEAR	S-TEXT
	EQUAL?	X,CLICK1,CLICK2 \?CND29
	CALL1	F-MOUSE-CARD-PICK >X
?CND29:	EQUAL?	X,146,147,148 /?CCL32
	EQUAL?	X,149 \?CND31
?CCL32:	SUB	X,97 >X
?CND31:	EQUAL?	X,49 \?PRD39
	GETB	F-CARD-TABLE,2
	ZERO?	STACK /?CTR36
?PRD39:	EQUAL?	X,50 \?PRD42
	GETB	F-CARD-TABLE,4
	ZERO?	STACK /?CTR36
?PRD42:	EQUAL?	X,51 \?PRD45
	GETB	F-CARD-TABLE,6
	ZERO?	STACK /?CTR36
?PRD45:	EQUAL?	X,52 \?CCL37
	GETB	F-CARD-TABLE,8
	ZERO?	STACK \?CCL37
?CTR36:	CLEAR	S-TEXT
	SOUND	1
	PRINTI	"You can't "
	GET	F-PLAY-TABLE-LC,PTR
	PRINT	STACK
	PRINTI	" that card; it hasn't been drawn yet!"
	ICALL1	2CR-TO-PRINTER
	JUMP	?PRG27
?CCL37:	EQUAL?	X,49 \?CCL51
	SET	'X,2
	JUMP	?REP28
?CCL51:	EQUAL?	X,50 \?CCL53
	SET	'X,4
	JUMP	?REP28
?CCL53:	EQUAL?	X,51 \?CCL55
	SET	'X,6
	JUMP	?REP28
?CCL55:	EQUAL?	X,52 \?CCL57
	SET	'X,8
?REP28:	GETB	F-CARD-TABLE,X >?TMP1
	ADD	X,1
	GETB	F-CARD-TABLE,STACK
	MUL	?TMP1,STACK
	MUL	STACK,PTR
	MOD	STACK,37 >NUM
	EQUAL?	PTR,5 \?CCL60
	GRTR?	F-WIN-COUNT,0 \?CCL63
	INC	'F-WIN-COUNT
	EQUAL?	F-WIN-COUNT,3 \?CND58
	DIV	X,2
	ADD	STACK,DRAW-CARDS-OFFSET
	FCLEAR	NOT-HERE-OBJECT,STACK
	PUTB	F-CARD-TABLE,X,0
	ADD	X,1
	PUTB	F-CARD-TABLE,STACK,0
	RFALSE	
?CCL57:	CLEAR	S-TEXT
	SOUND	1
	PRINT	TYPE-A-NUMBER
	PRINTI	"4."
	ICALL1	2CR-TO-PRINTER
	JUMP	?PRG27
?CCL63:	GET	J-LAST-CARD,0
	EQUAL?	STACK,TREBLED-RANK \?CND58
	GET	J-LAST-CARD,1
	EQUAL?	STACK,FROMP-SUIT \?CND58
	SET	'F-WIN-COUNT,1
	JUMP	?CND58
?CCL60:	SET	'F-WIN-COUNT,0
?CND58:	GET	F-SCORES,NUM
	ZERO?	STACK \?CCL71
	SET	'F-WIN-COUNT,0
	PRINTI	"   The jester is outraged! ""You can't "
	GET	F-PLAY-TABLE-LC,PTR
	PRINT	STACK
	PRINTC	32
	ICALL2	PRINT-CARD-NAME,X
	CALL2	PROB,6
	ZERO?	STACK /?CCL74
	PRINTI	" when "
	ICALL2	PRINT-CARD-NAME,0
	PRINTI	" is showing on the Discard Pile!"
	JUMP	?CND72
?CCL74:	PRINTC	32
	GET	J-RESPONSES,NUM
	PRINT	STACK
?CND72:	ICALL1	2CR-TO-PRINTER
	RFALSE	
?CCL71:	CLEAR	S-TEXT
	PRINTI	"You "
	GET	F-PLAY-TABLE-LC,PTR
	PRINT	STACK
	PRINTC	32
	ICALL2	PRINT-CARD-NAME,X
	PRINTI	". The jester "
	GET	J-RESPONSES,NUM
	PRINT	STACK
	PRINTC	32
	GET	F-SCORES,NUM
	ICALL2	F-SCORE,STACK
	EQUAL?	PTR,1 \?CND75
	FCLEAR	NOT-HERE-OBJECT,DRAW-CARDS-OFFSET
	GETB	F-CARD-TABLE,X
	PUTB	F-CARD-TABLE,0,STACK
	ADD	X,1
	GETB	F-CARD-TABLE,STACK
	PUTB	F-CARD-TABLE,1,STACK
?CND75:	DIV	X,2
	ADD	STACK,DRAW-CARDS-OFFSET
	FCLEAR	NOT-HERE-OBJECT,STACK
	PUTB	F-CARD-TABLE,X,0
	ADD	X,1
	PUTB	F-CARD-TABLE,STACK,0
	RFALSE	


	.FUNCT	F-MOUSE-CARD-PICK:ANY:0:0,TL-X,TL-Y,BR-X,BR-Y,CARD-WIDTH,CARD-HEIGHT
	PICINF	F-CARD,PICINF-TBL /?BOGUS1
?BOGUS1:	GET	PICINF-TBL,0 >CARD-HEIGHT
	GET	PICINF-TBL,1 >CARD-WIDTH
	ICALL2	PICINF-PLUS-ONE,F-1-PIC-LOC
	GET	PICINF-TBL,0 >TL-Y
	GET	PICINF-TBL,1 >TL-X
	ADD	TL-Y,CARD-HEIGHT >BR-Y
	ADD	TL-X,CARD-WIDTH >BR-X
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND2
	RETURN	49
?CND2:	ICALL2	PICINF-PLUS-ONE,F-2-PIC-LOC
	GET	PICINF-TBL,0 >TL-Y
	GET	PICINF-TBL,1 >TL-X
	ADD	TL-Y,CARD-HEIGHT >BR-Y
	ADD	TL-X,CARD-WIDTH >BR-X
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND4
	RETURN	50
?CND4:	ICALL2	PICINF-PLUS-ONE,F-3-PIC-LOC
	GET	PICINF-TBL,0 >TL-Y
	GET	PICINF-TBL,1 >TL-X
	ADD	TL-Y,CARD-HEIGHT >BR-Y
	ADD	TL-X,CARD-WIDTH >BR-X
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND6
	RETURN	51
?CND6:	ICALL2	PICINF-PLUS-ONE,F-4-PIC-LOC
	GET	PICINF-TBL,0 >TL-Y
	GET	PICINF-TBL,1 >TL-X
	ADD	TL-Y,CARD-HEIGHT >BR-Y
	ADD	TL-X,CARD-WIDTH >BR-X
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND8
	RETURN	52
?CND8:	RETURN	CLICK1


	.FUNCT	PRINT-CARD-NAME:ANY:1:1,CNT
	GETB	F-CARD-TABLE,CNT
	GET	F-RANK-TABLE,STACK
	PRINT	STACK
	GETB	F-CARD-TABLE,CNT
	LESS?	STACK,12 \FALSE
	PRINTC	32
	ADD	CNT,1
	GETB	F-CARD-TABLE,STACK
	GET	F-SUIT-TABLE,STACK
	PRINT	STACK
	RTRUE	


	.FUNCT	CHEAT-RESULT:ANY:1:1,TBL,CNT,X,PTS
	GET	TBL,0 >CNT
	RANDOM	CNT
	MUL	STACK,2
	SUB	STACK,1 >X
	ADD	X,1
	GET	TBL,STACK >PTS
	CLEAR	S-TEXT
	GET	TBL,X
	PRINT	STACK
	PRINTC	32
	CALL2	F-SCORE,PTS
	RSTACK	


	.FUNCT	F-SCORE:ANY:1:1,PTS
	GRTR?	PTS,0 \?CCL3
	DIV	YOUR-SCORE,10
	CALL2	PROB,STACK
	ZERO?	STACK /?CCL6
	GRTR?	J-SCORE,PTS \?CCL6
	SUB	J-SCORE,PTS >J-SCORE
	PRINTI	"The jester loses"
	JUMP	?CND1
?CCL6:	ADD	YOUR-SCORE,PTS >YOUR-SCORE
	PRINTI	"You gain"
	JUMP	?CND1
?CCL3:	MUL	PTS,-1 >PTS
	DIV	J-SCORE,10
	CALL2	PROB,STACK
	ZERO?	STACK /?CCL11
	GRTR?	YOUR-SCORE,PTS \?CCL11
	SUB	YOUR-SCORE,PTS >YOUR-SCORE
	PRINTI	"You lose"
	JUMP	?CND1
?CCL11:	ADD	J-SCORE,PTS >J-SCORE
	PRINTI	"The jester gains"
?CND1:	PRINTC	32
	PRINTN	PTS
	PRINTI	" points."
	CALL1	2CR-TO-PRINTER
	RSTACK	


	.FUNCT	QUILBOZZA-BEACH-F:ANY:0:1,RARG
	EQUAL?	RARG,M-ENTER \?CCL3
	PICINF	FOOZLE-SEGMENT-PIC,PICINF-TBL /FALSE
	RFALSE	
?CCL3:	EQUAL?	RARG,M-END \FALSE
	CALL2	PROB,40
	ZERO?	STACK /FALSE
	EQUAL?	CURRENT-SPLIT,MAP-TOP-LEFT-LOC /FALSE
	PRINTR	"   A wave crashes against the beach."


	.FUNCT	WARNING-ROOM-F:ANY:0:1,RARG
	EQUAL?	RARG,M-ENTER \?CCL3
	PICINF	FOOZLE-SEGMENT-PIC,PICINF-TBL /FALSE
	RFALSE	
?CCL3:	EQUAL?	RARG,M-BEG \FALSE
	EQUAL?	PRSA,V?EXAMINE,V?READ \FALSE
	EQUAL?	PRSO,SIGN \FALSE
	PRINTR	"""Warning! This area is populated by three races: the Veritassi (who always tell the truth), the Prevaricons (who always lie), and the Wishyfoo (who alternate with every statement). Be aware that visitors to Veritass and Prevaricon areas are immediately fed to ravenous hellhounds."""


	.FUNCT	ROOM-OF-THREE-DOORS-F:ANY:0:1,RARG
	EQUAL?	RARG,M-LOOK \?CCL3
	PRINTI	"Before you are three doors: left, center, and right. All three doors are closed, and have writing on them. In addition, a tunnel leads southwest."
	RTRUE	
?CCL3:	EQUAL?	RARG,M-END \?CCL5
	ZERO?	WRITING-CHANGED /?CCL5
	SET	'WRITING-CHANGED,FALSE-VALUE
	ICALL1	RETURN-FROM-MAP
	PRINTR	"   The writing on the doors appears to have changed since the last time you were here."
?CCL5:	EQUAL?	RARG,M-ENTER \?CCL9
	PICINF	FOOZLE-SEGMENT-PIC,PICINF-TBL /?BOGUS10
?BOGUS10:	FSET?	ROOM-OF-THREE-DOORS,TOUCHBIT \?CND11
	SET	'WRITING-CHANGED,TRUE-VALUE
?CND11:	CALL2	PROB,33
	ZERO?	STACK /?CCL15
	SET	'VERITASSI-DOOR,LEFT-DOOR
	CALL2	PROB,50
	ZERO?	STACK /?CCL18
	SET	'PREVARICON-DOOR,RIGHT-DOOR
	SET	'WISHYFOO-DOOR,CENTER-DOOR
	RETURN	WISHYFOO-DOOR
?CCL18:	SET	'PREVARICON-DOOR,CENTER-DOOR
	SET	'WISHYFOO-DOOR,RIGHT-DOOR
	RETURN	WISHYFOO-DOOR
?CCL15:	CALL2	PROB,50
	ZERO?	STACK /?CCL20
	SET	'VERITASSI-DOOR,RIGHT-DOOR
	CALL2	PROB,50
	ZERO?	STACK /?CCL23
	SET	'PREVARICON-DOOR,LEFT-DOOR
	SET	'WISHYFOO-DOOR,CENTER-DOOR
	RETURN	WISHYFOO-DOOR
?CCL23:	SET	'PREVARICON-DOOR,CENTER-DOOR
	SET	'WISHYFOO-DOOR,LEFT-DOOR
	RETURN	WISHYFOO-DOOR
?CCL20:	SET	'VERITASSI-DOOR,CENTER-DOOR
	CALL2	PROB,50
	ZERO?	STACK /?CCL26
	SET	'PREVARICON-DOOR,LEFT-DOOR
	SET	'WISHYFOO-DOOR,RIGHT-DOOR
	RETURN	WISHYFOO-DOOR
?CCL26:	SET	'PREVARICON-DOOR,RIGHT-DOOR
	SET	'WISHYFOO-DOOR,LEFT-DOOR
	RETURN	WISHYFOO-DOOR
?CCL9:	EQUAL?	PRSA,V?UNDO,V?SAVE \FALSE
	PRINTR	"[You can't SAVE or UNDO here. You'll have to solve the puzzle!]"


	.FUNCT	THREE-DOORS-F:ANY:0:0
	EQUAL?	PRSA,V?READ \?CCL3
	PRINTI	"""Attention:
1. This door does not lead to Prevaricon territory.
2. The "
	EQUAL?	PRSO,VERITASSI-DOOR \?CCL6
	ICALL2	DPRINT,PREVARICON-DOOR
	PRINT	STR?812
	PRINTI	"Wishyfoo"
	JUMP	?CND4
?CCL6:	EQUAL?	PRSO,PREVARICON-DOOR \?CCL8
	ICALL2	DPRINT,WISHYFOO-DOOR
	PRINT	STR?812
	PRINTI	"Wishyfoo"
	JUMP	?CND4
?CCL8:	ICALL2	DPRINT,VERITASSI-DOOR
	PRINT	STR?812
	PRINTI	"Veritassi"
?CND4:	PRINTR	" territory."""
?CCL3:	EQUAL?	PRSA,V?ENTER,V?OPEN \FALSE
	PRINTI	"As you open it, a strong draft sucks you through the doorway. You stumble down a steep incline"
	PRINT	ELLIPSIS
	EQUAL?	PRSO,WISHYFOO-DOOR \?CCL13
	CALL2	GOTO,WISHYFOO-TERRITORY
	RSTACK	
?CCL13:	HLIGHT	H-BOLD
	EQUAL?	PRSO,VERITASSI-DOOR \?CCL16
	PRINTI	"Veritassi"
	JUMP	?CND14
?CCL16:	PRINTI	"Prevaricon"
?CND14:	PRINTI	" Territory"
	CRLF	
	HLIGHT	H-NORMAL
	CALL2	JIGS-UP,STR?813
	RSTACK	

	.ENDSEG

	.ENDI
