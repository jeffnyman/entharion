
	.SEGMENT "LOWER"


	.FUNCT	EXIT-F:ANY:0:1,RARG
	EQUAL?	RARG,M-ENTER \?CCL3
	PICINF	LOWER-SEGMENT-PIC,PICINF-TBL /FALSE
	RFALSE	
