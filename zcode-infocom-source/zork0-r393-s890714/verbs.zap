	SET	'P-LEN,P-WORDS-AGAIN
	PRINTR	"[Uh, the quotation marks confused me...]"
?CCL5:	PRINTI	"You look up """
	CALL2	GET-NP,PRSO
	ICALL2	NP-PRINT,STACK
	PRINTR	""" in the encyclopedia, but find no entry."


