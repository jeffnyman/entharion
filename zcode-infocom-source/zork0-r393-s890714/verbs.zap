	FIRST?	DELTA-7 \?CND85
	ICALL	DISPLAY-ROOM,RUBBLE-SE-CON,MAP-GEN-Y-5,MAP-GEN-X-7,MAP-BOX-HEIGHT,MAP-BOX-WIDTH
?CND85:	FIRST?	DELTA-2 \?CND89
	FIRST?	DELTA-3 \?CND89
	CALL2	MAP-X,2-3-CON-SIZE
