
	.SEGMENT "0"


	.FUNCT	V-VERBOSE:ANY:0:0
	SET	'VERBOSITY,2
	PRINTI	"Maximum verbosity."
	CRLF	
	CRLF	
	CALL1	V-LOOK
	RSTACK	


	.FUNCT	V-BRIEF:ANY:0:0
	SET	'VERBOSITY,1
	PRINTR	"Brief descriptions."


	.FUNCT	V-SUPERBRIEF:ANY:0:0
	SET	'VERBOSITY,0
	PRINTR	"Superbrief descriptions."


	.FUNCT	NOT-IN-DEMO:ANY:0:0
	PRINTR	"[Sorry, but that command is not available in this demonstration version.]"


	.FUNCT	V-SAVE:ANY:0:0,X
	ZERO?	DEMO-VERSION? /?CND1
	ICALL1	NOT-IN-DEMO
	RETURN	2
?CND1:	PUTB	G-INBUF,2,0
	SET	'P-CONT,FALSE-VALUE
	SAVE	 >X
	ZERO?	X \?CCL7
	SET	'P-CONT,-1
	PRINTI	"SAVE failed!"
	CRLF	
	RETURN	2
?CCL7:	EQUAL?	X,1 \?CND5
	ICALL1	RESTORE-ORPHAN
	PRINTI	"SAVE completed."
	CRLF	
	RETURN	2
?CND5:	COLOR	FG-COLOR,BG-COLOR
	SET	'OLD-HERE,FALSE-VALUE
	ICALL1	SETUP-SCREEN
	ICALL1	V-$REFRESH
	ICALL1	RESTORE-ORPHAN
	PRINTI	"Okay, restored."
	CRLF	
	CRLF	
	SET	'P-CONT,-1
	CALL1	APPLE?
	ZERO?	STACK /?CND13
	GETP	HERE,P?ACTION
	ICALL	STACK,M-ENTER
?CND13:	CALL1	V-LOOK
	RSTACK	


	.FUNCT	RESTORE-ORPHAN:ANY:0:0
	IN?	JESTER,HERE \FALSE
	ZERO?	LIT /FALSE
	EQUAL?	HERE,ENTRANCE-HALL \?PRD8
	FSET?	PORTCULLIS,OPENBIT \?CCL3
?PRD8:	EQUAL?	HERE,SOLAR \?PRD11
	IN?	EAST-KEY,JESTER /?CCL3
?PRD11:	EQUAL?	HERE,OUBLIETTE /?CCL3
	EQUAL?	HERE,CAVE-IN \?PRD15
	IN?	PIT-BOMB,LOCAL-GLOBALS /?CCL3
?PRD15:	EQUAL?	HERE,TAX-OFFICE \?PRD18
	IN?	ZORKMID-COIN,LOCAL-GLOBALS /?CCL3
?PRD18:	EQUAL?	HERE,STREAM \FALSE
	FSET?	DIPLOMA,TRYTAKEBIT \FALSE
?CCL3:	CALL2	SETUP-ORPHAN,STR?38
	RSTACK	


	.FUNCT	V-RESTORE:ANY:0:0
	ZERO?	DEMO-VERSION? /?CND1
	ICALL1	NOT-IN-DEMO
	RETURN	2
?CND1:	RESTORE	
	ZERO?	STACK \FALSE
	PRINT	FAILED
	RTRUE	


	.FUNCT	V-UNDO:ANY:0:0,X
	GET	0,8
	BTST	STACK,16 /?CND1
	PRINTR	"UNDO is unavailable on your computer system."
?CND1:	IRESTORE	
	PRINT	FAILED
	RTRUE	


	.FUNCT	V-SCRIPT:ANY:0:0
	ZERO?	DEMO-VERSION? /?CND1
	ICALL1	NOT-IN-DEMO
	RETURN	2
?CND1:	PRINTI	"[Transcript on.]"
	CRLF	
	DIROUT	D-PRINTER-ON
	CALL2	CORP-NOTICE,STR?39
	RSTACK	


	.FUNCT	V-UNSCRIPT:ANY:0:0
	ZERO?	DEMO-VERSION? /?CND1
	ICALL1	NOT-IN-DEMO
	RETURN	2
?CND1:	ICALL2	CORP-NOTICE,STR?40
	DIROUT	D-PRINTER-OFF
	PRINTR	"[Transcript off.]"


	.FUNCT	CORP-NOTICE:ANY:1:1,STRING
	DIROUT	D-SCREEN-OFF
	CRLF	
	PRINTI	"Here "
	PRINT	STRING
	PRINTI	" a transcript of interaction with"
	CRLF	
	ICALL1	V-VERSION
	CRLF	
	DIROUT	D-SCREEN-ON
	RTRUE	


	.FUNCT	2CR-TO-PRINTER:ANY:0:0
	DIROUT	D-SCREEN-OFF
	CRLF	
	CRLF	
	DIROUT	D-SCREEN-ON
	RTRUE	


	.FUNCT	V-COLOR:ANY:0:0,DEFAULT
	CALL1	APPLE?
	ZERO?	STACK /?CCL3
	PRINTR	"[So sorry -- you can't change your text and background colors on this system.]"
?CCL3:	ZERO?	COLOR-NOTE \?CND1
	SET	'COLOR-NOTE,TRUE-VALUE
	PRINTI	"Aesthetically, we recommend not changing the standard setting, which is "
	CALL1	APPLE?
	ZERO?	STACK \?CTR6
	GETB	0,30
	EQUAL?	STACK,IBM \?CCL7
	GET	0,8
	BTST	STACK,64 /?CCL7
?CTR6:	PRINTI	"white"
	JUMP	?CND5
?CCL7:	PRINTI	"black"
?CND5:	PRINTI	" text on a "
	CALL1	APPLE?
	ZERO?	STACK \?CTR13
	GETB	0,30
	EQUAL?	STACK,IBM \?CCL14
	GET	0,8
	BTST	STACK,64 /?CCL14
?CTR13:	PRINTI	"black"
	JUMP	?CND12
?CCL14:	GETB	0,30
	EQUAL?	STACK,AMIGA \?CCL20
	PRINTI	"light gray"
	JUMP	?CND12
?CCL20:	PRINTI	"white"
?CND12:	PRINTI	" background. "
	GETB	0,30
	EQUAL?	STACK,MACINTOSH \?CND21
	CALL1	MAC-II?
	ZERO?	STACK /?CND21
	PRINTI	"Also, if your Mac II displays only 16 colors, you probably won't get the color you ask for. "
?CND21:	PRINTI	"Do you still want to go ahead?"
	CRLF	
	PRINTI	"(Y or N) >"
	CALL1	Y?
	ZERO?	STACK /TRUE
?CND1:	CRLF	
?PRG27:	ICALL1	DO-COLOR
	PRINTI	"You should now get "
	GET	COLOR-TABLE,FG-COLOR
	PRINT	STACK
	PRINTI	" text on a "
	GET	COLOR-TABLE,BG-COLOR
	PRINT	STACK
	PRINTI	" background. Is that what you want?
(Y or N) >"
	CALL1	Y?
	ZERO?	STACK \?REP28
	CALL1	MAC-I-COLOR-SWITCH
	ZERO?	STACK \?REP28
	CRLF	
	PRINTI	"Do you want to pick again, or would you like to just go back to the standard colors? (Type Y to pick again) >"
	CALL1	Y?
	ZERO?	STACK /?CCL35
	CRLF	
	JUMP	?PRG27
?CCL35:	SET	'DEFAULT,TRUE-VALUE
?REP28:	ZERO?	DEFAULT /?CCL38
	ICALL1	DEFAULT-COLORS
	JUMP	?CND36
?CCL38:	COLOR	FG-COLOR,BG-COLOR
	SCREEN	S-FULL
	COLOR	FG-COLOR,BG-COLOR
	SCREEN	S-TEXT
?CND36:	CALL1	V-$REFRESH
	RSTACK	


	.FUNCT	MAC-I-COLOR-SWITCH:ANY:0:0
	GETB	0,30
	EQUAL?	STACK,IBM \?PRD5
	GET	0,8
	BTST	STACK,64 \?CCL3
?PRD5:	GETB	0,30
	EQUAL?	STACK,MACINTOSH \FALSE
	CALL1	MAC-II?
	ZERO?	STACK \FALSE
?CCL3:	EQUAL?	BG-COLOR,2 \?CCL12
	SET	'BG-COLOR,9
	SET	'FG-COLOR,2
	RTRUE	
?CCL12:	SET	'BG-COLOR,2
	SET	'FG-COLOR,9
	RTRUE	


	.FUNCT	DO-COLOR:ANY:0:0
	CALL1	MAC-I-COLOR-SWITCH
	ZERO?	STACK \TRUE
	CALL	PICK-COLOR,FG-COLOR,STR?41,TRUE-VALUE >FG-COLOR
	CALL	PICK-COLOR,BG-COLOR,STR?42 >BG-COLOR
	RETURN	BG-COLOR


	.FUNCT	PICK-COLOR:ANY:2:3,WHICH,STRING,SETTING-FG,CHAR
	PRINTI	"The current "
	PRINT	STRING
	PRINTI	" color is "
	GET	COLOR-TABLE,WHICH
	PRINT	STACK
	PRINT	PERIOD-CR
	FONT	4
	PRINTI	"   1 --> WHITE   4 --> GREEN"
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CND1
	PRINTI	"    7 --> LIGHT GRAY"
?CND1:	CRLF	
	PRINTI	"   2 --> BLACK   5 --> YELLOW"
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CND3
	PRINTI	"   8 --> MEDIUM GRAY"
?CND3:	CRLF	
	PRINTI	"   3 --> RED     6 --> BLUE"
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CND5
	PRINTI	"     9 --> DARK GRAY"
?CND5:	CRLF	
	FONT	1
	PRINTI	"Type a number to select the "
	PRINT	STRING
	PRINTI	" color you want. >"
?PRG7:	ZERO?	DEMO-VERSION? /?CCL11
	CALL2	INPUT-DEMO,1 >CHAR
	JUMP	?CND9
?CCL11:	INPUT	1 >CHAR
?CND9:	SUB	CHAR,48 >CHAR
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CCL14
	EQUAL?	CHAR,7,8,9 \?CCL14
	ADD	CHAR,3 >CHAR
	JUMP	?CND12
?CCL14:	EQUAL?	CHAR,1 \?CND12
	SET	'CHAR,9
?CND12:	EQUAL?	CHAR,2,3,4 /?CTR19
	EQUAL?	CHAR,5,6,9 /?CTR19
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CCL20
	EQUAL?	CHAR,10,11,12 \?CCL20
?CTR19:	ZERO?	SETTING-FG \?REP8
	EQUAL?	CHAR,FG-COLOR \?REP8
	CRLF	
	PRINTI	"You can't make the background the same color as the text! Pick another color. >"
	JUMP	?PRG7
?CCL20:	CRLF	
	PRINT	TYPE-A-NUMBER
	GETB	0,30
	EQUAL?	STACK,AMIGA \?CCL33
	PRINTC	57
	JUMP	?CND31
?CCL33:	PRINTC	54
?CND31:	PRINTI	". >"
	JUMP	?PRG7
?REP8:	CRLF	
	CRLF	
	RETURN	CHAR


	.FUNCT	DEFAULT-COLORS:ANY:0:0
	SET	'FG-COLOR,DEFAULT-FG
	SET	'BG-COLOR,DEFAULT-BG
	COLOR	FG-COLOR,BG-COLOR
	SCREEN	S-FULL
	COLOR	FG-COLOR,BG-COLOR
	SCREEN	S-TEXT
	RTRUE	


	.FUNCT	V-CREDITS:ANY:0:0
	ICALL	CENTER-1,STR?56,TRUE-VALUE
	ICALL	CENTER-1,STR?57,TRUE-VALUE
	CRLF	
	ICALL	CENTER-1,STR?58,TRUE-VALUE
	ICALL2	CENTER-1,STR?59
	CRLF	
	ICALL	CENTER-1,STR?60,TRUE-VALUE
	ICALL	CENTER-2,STR?61,STR?62
	ICALL	CENTER-2,STR?63,STR?59
	CRLF	
	ICALL	CENTER-1,STR?64,TRUE-VALUE
	ICALL2	CENTER-1,STR?65
	CRLF	
	ICALL	CENTER-1,STR?66,TRUE-VALUE
	ICALL	CENTER-3,STR?67,STR?68,STR?69
	ICALL	CENTER-3,STR?70,STR?71,STR?72
	ICALL2	CENTER-1,STR?73
	CRLF	
	ICALL	CENTER-1,STR?74,TRUE-VALUE
	ICALL	CENTER-2,STR?61,STR?75
	CRLF	
	ICALL	CENTER-1,STR?76,TRUE-VALUE
	ICALL	CENTER-2,STR?61,STR?63
	CRLF	
	ICALL	CENTER-1,STR?77,TRUE-VALUE
	ICALL2	CENTER-1,STR?78
	ICALL2	CENTER-1,STR?79
	ICALL2	CENTER-1,STR?80
	ICALL2	CENTER-1,STR?81
	CRLF	
	ICALL	CENTER-1,STR?82,TRUE-VALUE
	ICALL	CENTER-3,STR?83,STR?84,STR?85
	ICALL	CENTER-3,STR?86,STR?87,STR?88
	ICALL	CENTER-3,STR?89,STR?90,STR?91
	ICALL	CENTER-3,STR?92,STR?93,STR?94
	ICALL	CENTER-2,STR?95,STR?96
	CRLF	
	ICALL	CENTER-1,STR?97,TRUE-VALUE
	ICALL	CENTER-2,STR?98,STR?99
	CRLF	
	ICALL	CENTER-1,STR?100,TRUE-VALUE
	ICALL	CENTER-2,STR?85,STR?99
	ICALL2	CENTER-1,STR?59
	CRLF	
	ICALL	CENTER-1,STR?101,TRUE-VALUE
	CALL2	CENTER-1,STR?102
	RSTACK	


	.FUNCT	CENTER-1:ANY:1:2,STR,BOLD,Y,X,LEN
	ZERO?	BOLD /?CCL3
	PUSH	H-BOLD
	JUMP	?CND1
?CCL3:	PUSH	0
?CND1:	ICALL	CENTER-LINE,STR,0,STACK
	CRLF	
	RTRUE	


	.FUNCT	CENTER-2:ANY:2:2,STR1,STR2,Y,X1,X2,LEN
	CURGET	SLINE
	GET	SLINE,0 >Y
	WINGET	S-TEXT,WWIDE
	DIV	STACK,3 >X1
	MUL	X1,2 >X2
	DIROUT	D-TABLE-ON,SLINE
	PRINT	STR1
	DIROUT	D-TABLE-OFF
	GET	0,24 >LEN
	DIV	LEN,2
	SUB	X1,STACK
	CURSET	Y,STACK
	PRINT	STR1
	DIROUT	D-TABLE-ON,SLINE
	PRINT	STR2
	DIROUT	D-TABLE-OFF
	GET	0,24 >LEN
	DIV	LEN,2
	SUB	X2,STACK
	CURSET	Y,STACK
	PRINT	STR2
	CRLF	
	RTRUE	


	.FUNCT	CENTER-3:ANY:3:3,STR1,STR2,STR3,Y,X1,X2,X3,LEN
	CURGET	SLINE
	GET	SLINE,0 >Y
	WINGET	S-TEXT,WWIDE
	DIV	STACK,4 >X1
	MUL	X1,2 >X2
	MUL	X1,3 >X3
	DIROUT	D-TABLE-ON,SLINE
	PRINT	STR1
	DIROUT	D-TABLE-OFF
	GET	0,24 >LEN
	DIV	LEN,2
	SUB	X1,STACK
	CURSET	Y,STACK
	PRINT	STR1
	DIROUT	D-TABLE-ON,SLINE
	PRINT	STR2
	DIROUT	D-TABLE-OFF
	GET	0,24 >LEN
	DIV	LEN,2
	SUB	X2,STACK
	CURSET	Y,STACK
	PRINT	STR2
	DIROUT	D-TABLE-ON,SLINE
	PRINT	STR3
	DIROUT	D-TABLE-OFF
	GET	0,24 >LEN
	DIV	LEN,2
	SUB	X3,STACK
	CURSET	Y,STACK
	PRINT	STR3
	CRLF	
	RTRUE	


	.FUNCT	V-DIAGNOSE:ANY:0:0
	GRTR?	DESERT-DEATH,0 \?CCL3
	PRINTI	"You're "
	GRTR?	DESERT-DEATH,4 \?CCL6
	PRINTI	"about to pass out"
	JUMP	?CND4
?CCL6:	GRTR?	DESERT-DEATH,2 \?CCL8
	PRINTI	"dangerously close to passing out"
	JUMP	?CND4
?CCL8:	PRINTI	"feeling a bit faint"
?CND4:	PRINTR	" from the heat."
?CCL3:	ZERO?	ALLIGATOR /?CCL10
	PRINTR	"You're a perfectly healthy alligator."
?CCL10:	ZERO?	TURNED-INTO /?CCL12
	EQUAL?	TURNED-INTO,VIOLIN \?CCL15
	PRINTR	"You're fit as a fiddle. In fact, you ARE a fiddle."
?CCL15:	PRINTI	"You are"
	ICALL2	APRINT,TURNED-INTO
	PRINTR	". Other details of health pale in comparison."
?CCL12:	FSET?	CLOWN-NOSE,WORNBIT \?CCL17
	PRINTI	"You're having a bit of trouble breathing, thanks to the "
	ICALL2	DPRINT,CLOWN-NOSE
	PRINTR	" on your nose."
?CCL17:	GRTR?	HUNGER-COUNT,0 \?CCL19
	PRINTI	"You feel "
	EQUAL?	HUNGER-COUNT,2 \?CCL22
	PRINTI	"very "
	JUMP	?CND20
?CCL22:	EQUAL?	HUNGER-COUNT,3 \?CND20
	PRINTI	"incredibly "
?CND20:	PRINTR	"hungry."
?CCL19:	PRINTR	"You're as fit as a fiddle."


	.FUNCT	V-INVENTORY:ANY:0:0
	SUB	0,WORNBIT >D-BIT
	ADD	D-ALL?,D-PARA?
	CALL	D-CONTENTS,WINNER,FALSE-VALUE,STACK
	ZERO?	STACK \?CND1
	ZERO?	TURNED-INTO /?CCL5
	PRINTI	"You are carrying nothing."
	JUMP	?CND1
?CCL5:	PRINTI	"You are empty-"
	ZERO?	ALLIGATOR /?CCL8
	PRINTI	"claw"
	JUMP	?CND6
?CCL8:	PRINTI	"hand"
?CND6:	PRINTI	"ed."
?CND1:	SET	'D-BIT,WORNBIT
	ADD	D-ALL?,D-PARA?
	ICALL	D-CONTENTS,WINNER,FALSE-VALUE,STACK
	SET	'D-BIT,FALSE-VALUE
	FSET?	GLOVE,WORNBIT \?CND9
	ZERO?	GLOVE-COMMENT \?CND9
	SET	'GLOVE-COMMENT,TRUE-VALUE
	PRINTR	" [It's probably none of my business, but when you wear that single glove you resemble singer Michael Flathead, formerly of the Flathead Five.]"
?CND9:	CRLF	
	RTRUE	


	.FUNCT	V-MODE:ANY:0:0
	CLEAR	-1
	ZERO?	BORDER-ON /?CCL3
	SET	'BORDER-ON,FALSE-VALUE
	JUMP	?CND1
?CCL3:	SET	'BORDER-ON,TRUE-VALUE
?CND1:	SCREEN	S-FULL
	ICALL2	INIT-STATUS-LINE,TRUE-VALUE
	SCREEN	S-TEXT
	PRINTI	"Border o"
	ZERO?	BORDER-ON /?CCL6
	PRINTC	110
	JUMP	?CND4
?CCL6:	PRINTI	"ff"
?CND4:	PRINTR	" (obviously)."


	.FUNCT	V-QUIT:ANY:0:0
	ICALL1	V-SCORE
	ICALL2	DO-YOU-WISH,STR?103
	CALL1	Y?
	ZERO?	STACK /?CCL3
	QUIT	
	RTRUE	
?CCL3:	PRINT	OK
	RTRUE	


	.FUNCT	V-RESTART:ANY:0:0
	ICALL1	V-SCORE
	ICALL2	DO-YOU-WISH,STR?104
	CALL1	Y?
	ZERO?	STACK /FALSE
	PRINTI	"Restarting."
	CRLF	
	ICALL1	DEFAULT-COLORS
	RESTART	
	PRINT	FAILED
	RTRUE	


	.FUNCT	DO-YOU-WISH:ANY:1:1,STRING
	CRLF	
	PRINTI	"Do you really want to "
	PRINT	STRING
	PRINTI	" (y or n)? >"
	RTRUE	


	.FUNCT	FINISH:ANY:0:0,REPEATING,CNT,?TMP1,?TMP2
?PRG1:	CRLF	
	ZERO?	REPEATING \?CND3
	SET	'REPEATING,TRUE-VALUE
	ICALL1	V-SCORE
?CND3:	ICALL1	UPDATE-STATUS-LINE
	PRINTI	"Would you like to start over, restore a saved position, "
	GET	0,8
	BTST	STACK,16 \?CND5
	EQUAL?	HERE,ROOM-OF-THREE-DOORS /?CND5
	PRINTI	"undo your last turn, "
?CND5:	PRINTI	"end this session of the game, or "
	EQUAL?	SCORE,1000 \?CCL11
	PRINTI	"see the credits?"
	CRLF	
	JUMP	?CND9
?CCL11:	PRINTI	"get a hint?"
	CRLF	
?CND9:	PRINTI	"(Type RESTART, RESTORE, "
	GET	0,8
	BTST	STACK,16 \?CND12
	EQUAL?	HERE,ROOM-OF-THREE-DOORS /?CND12
	PRINTI	"UNDO, "
?CND12:	PRINTI	"QUIT, or "
	EQUAL?	SCORE,1000 \?CCL18
	PRINTI	"CREDITS"
	JUMP	?CND16
?CCL18:	PRINTI	"HINT"
?CND16:	PRINTI	"):"
	WINGET	S-TEXT,WWIDE >?TMP2
	WINGET	S-TEXT,WXPOS
	SUB	?TMP2,STACK >?TMP1
	MUL	FONT-X,9
	LESS?	?TMP1,STACK \?CCL21
	CRLF	
	JUMP	?CND19
?CCL21:	PRINTC	32
?CND19:	PRINTC	62
	PUTB	P-LEXV,0,10
	PUTB	P-INBUF,1,0
	ZERO?	DEMO-VERSION? /?CCL24
	ICALL	READ-DEMO,P-INBUF,P-LEXV
	JUMP	?CND22
?CCL24:	READ	P-INBUF,P-LEXV
?CND22:	ICALL1	MOUSE-INPUT?
	PUTB	P-LEXV,0,LEXV-LENGTH
	INC	'CNT
	ICALL1	2CR-TO-PRINTER
	GET	P-LEXV,1
	EQUAL?	STACK,W?RESTART \?CCL27
	ICALL1	DEFAULT-COLORS
	RESTART	
	PRINT	FAILED
	JUMP	?PRG1
?CCL27:	GET	P-LEXV,1
	EQUAL?	STACK,W?RESTORE \?CCL29
	RESTORE	
	ZERO?	STACK \?CCL29
	PRINT	FAILED
	JUMP	?PRG1
?CCL29:	GET	P-LEXV,1
	EQUAL?	STACK,W?QUIT,W?Q /?CTR32
	GRTR?	CNT,10 \?CCL33
?CTR32:	QUIT	
	JUMP	?PRG1
?CCL33:	GET	P-LEXV,1
	EQUAL?	STACK,W?UNDO \?CCL37
	CALL1	V-UNDO
	ZERO?	STACK \?PRG1
?CCL37:	GET	P-LEXV,1
	EQUAL?	STACK,W?CREDIT,W?CREDITS \?CCL41
	ICALL1	V-CREDITS
	JUMP	?PRG1
?CCL41:	GET	P-LEXV,1
	EQUAL?	STACK,W?HINTS,W?HINT,W?HELP /?CCL43
	GET	P-LEXV,1
	EQUAL?	STACK,W?CLUE,W?CLUES \?PRG1
?CCL43:	ICALL1	V-HINT
	JUMP	?PRG1


	.FUNCT	V-VERSION:ANY:0:0,IDX
	SET	'IDX,18
	PRINTI	"ZORK ZERO: The Revenge of Megaboz
Copyright (c) 1988 by Infocom, Inc. All rights reserved.
ZORK is a registered trademark of Infocom, Inc."
	CRLF	
	ICALL1	INTERPRETER-ID
	PRINTI	"Release "
	GET	0,1
	BAND	STACK,2047
	PRINTN	STACK
	PICINF	0,PICINF-TBL /?BOGUS1
?BOGUS1:	PRINTI	" / Pix "
	GET	PICINF-TBL,1
	PRINTN	STACK
	PRINTI	" / Serial number "
?PRG2:	GETB	0,IDX
	PRINTC	STACK
	IGRTR?	'IDX,23 \?PRG2
	CRLF	
	RTRUE	


	.FUNCT	INTERPRETER-ID:ANY:0:0
	GETB	0,30
	GET	MACHINES,STACK
	PRINT	STACK
	PRINTI	" Interpreter version "
	GETB	0,0
	PRINTN	STACK
	PRINTC	46
	GETB	0,31
	PRINTN	STACK
	CRLF	
	RTRUE	


	.FUNCT	MAC-II?:ANY:0:0
	GET	SL-LOC-TBL,10
	ZERO?	STACK /TRUE
	RFALSE	

	.ENDSEG

	.SEGMENT "STARTUP"


	.FUNCT	V-$COMMAND:ANY:0:0
	DIRIN	1
	RTRUE	


	.FUNCT	V-$RANDOM:ANY:0:0
	EQUAL?	PRSO,INTNUM /?CCL3
	PRINTR	"ILLEGAL."
?CCL3:	SUB	0,P-NUMBER
	RANDOM	STACK
	RTRUE	


	.FUNCT	V-$RECORD:ANY:0:0
	DIROUT	D-RECORD-ON
	RTRUE	


	.FUNCT	V-$UNRECORD:ANY:0:0
	DIROUT	D-RECORD-OFF
	RTRUE	


	.FUNCT	V-$VERIFY:ANY:0:0
	EQUAL?	PRSO,INTNUM \?CCL3
	EQUAL?	P-NUMBER,232 \?CCL3
	PRINTN	SERIAL
	CRLF	
	RTRUE	
?CCL3:	ICALL1	INTERPRETER-ID
	PRINTI	"Verifying..."
	CRLF	
	VERIFY	 \?CCL8
	PRINT	OK
