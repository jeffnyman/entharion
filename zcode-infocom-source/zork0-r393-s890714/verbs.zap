	.FUNCT	V-LOOK-INSIDE:ANY:0:0,X-RAYED
	FSET?	PRSO,ACTORBIT \?CCL3
	PRINT	IT-SEEMS-THAT
	ICALL1	TPRINT-PRSO
	PRINTI	" has"
	CALL1	D-NOTHING
	ZERO?	STACK \TRUE
	PRINT	PERIOD-CR
	RTRUE	
?CCL3:	IN?	PROTAGONIST,PRSO \?CCL7
	CALL1	D-VEHICLE
	RSTACK	
?CCL7:	FSET?	PRSO,DOORBIT \?CCL9
	PRINTI	"All you can tell is that"
	ICALL1	TPRINT-PRSO
	PRINTI	" is "
	ICALL2	OPEN-CLOSED,PRSO
	PRINT	PERIOD-CR
	RTRUE	
?CCL9:	GET	PARSE-RESULT,7
	EQUAL?	STACK,W?OUT \?CCL11
	PRINTR	"You see nothing special."
?CCL11:	FSET?	PRSO,SURFACEBIT \?CCL13
	PRINTI	"On the surface of"
	ICALL1	TPRINT-PRSO
	PRINTI	" you see"
	CALL1	D-NOTHING
	ZERO?	STACK \TRUE
	PRINT	PERIOD-CR
	RTRUE	
?CCL13:	FSET?	PRSO,VEHBIT \?CCL17
	FIRST?	PRSO /?CCL17
	FSET?	PRSO,OPENBIT /?CCL22
	ICALL	DO-FIRST,STR?142,PRSO
	RTRUE	
?CCL22:	FSET?	PRSO,OPENBIT /?CND20
	FSET?	PRSO,TRANSBIT /?CND20
	FSET?	GOGGLES,WORNBIT \?CND20
	SET	'X-RAYED,TRUE-VALUE
	ICALL1	DISCOVER-X-RAY
?CND20:	PRINTI	"There is no one "
	FSET?	PRSO,INBIT \?CCL29
	PRINTC	105
	JUMP	?CND27
?CCL29:	PRINTC	111
?CND27:	PRINTC	110
	CALL2	TRPRINT,PRSO
	RSTACK	
?CCL17:	FSET?	PRSO,CONTBIT \?CCL31
	FSET?	PRSO,OPENBIT /?CND32
	FSET?	PRSO,TRANSBIT /?CND32
	FSET?	GOGGLES,WORNBIT \?CND32
	SET	'X-RAYED,TRUE-VALUE
	ICALL1	DISCOVER-X-RAY
?CND32:	CALL2	SEE-INSIDE?,PRSO
	ZERO?	STACK /?CCL39
	PRINTI	"Within"
	ICALL1	TPRINT-PRSO
	PRINTI	" you see"
	CALL1	D-NOTHING
	ZERO?	STACK \?CND40
	PRINT	PERIOD-CR
?CND40:	ZERO?	X-RAYED /TRUE
	PRINTI	"   After a moment, the power of the goggles wanes, and"
	ICALL1	TPRINT-PRSO
	PRINTR	" no longer seems transparent."
?CCL39:	FSET?	PRSO,OPENBIT /?CCL45
	FIRST?	PRSO \?CCL45
	GET	PARSE-RESULT,7
	EQUAL?	STACK,W?IN \?CCL45
	CALL2	UNTOUCHABLE?,PRSO
	ZERO?	STACK /?CND49
	ICALL2	CANT-REACH,PRSO
	RTRUE	
?CND49:	ICALL	PERFORM,V?OPEN,PRSO
	RTRUE	
?CCL45:	CALL	DO-FIRST,STR?142,PRSO
	RSTACK	
?CCL31:	GET	PARSE-RESULT,7
	EQUAL?	STACK,W?IN \?CCL52
	CALL2	CANT-VERB-A-PRSO,STR?143
	RSTACK	
?CCL52:	CALL2	CANT-VERB-A-PRSO,STR?144
	RSTACK	


	.FUNCT	V-LOOK-OVER:ANY:0:0
	CALL1	V-EXAMINE
	RSTACK	


	.FUNCT	V-LOOK-UNDER:ANY:0:0
	CALL2	ULTIMATELY-IN?,PRSO
	ZERO?	STACK /?CCL3
	EQUAL?	PRSO,WALDO /?CCL3
	IN?	PRSO,WALDO /?CCL3
	FSET?	PRSO,WORNBIT \?CCL9
	PRINTR	"You're wearing it!"
?CCL9:	PRINT	HOLDING-IT
	RTRUE	
?CCL3:	FSET?	PRSO,WATERBIT \?CCL11
	CALL2	PERFORM-PRSA,WATER
	RSTACK	
?CCL11:	PRINTI	"There is nothing but "
	IN?	PRSO,MIRROR-LAKE \?CCL14
	PRINTI	"ice"
	JUMP	?CND12
?CCL14:	LOC	PRSO
	FSET?	STACK,DELTABIT \?CCL16
	PRINTI	"swamp"
	JUMP	?CND12
?CCL16:	EQUAL?	PRSO,EAST-DOCK,SOUTH-DOCK,NORTH-DOCK /?CTR17
	EQUAL?	PRSO,WHARF,YACHT,WEST-DOCK /?CTR17
	EQUAL?	PRSO,BRIDGE /?CTR17
	EQUAL?	PRSO,DRAWBRIDGE /?PRD25
	EQUAL?	PRSO,GLOBAL-HERE \?PRD23
	EQUAL?	HERE,DRAWBRIDGE \?PRD23
?PRD25:	FSET?	DRAWBRIDGE,OPENBIT /?CTR17
?PRD23:	EQUAL?	HERE,LAKE-BOTTOM \?PRD30
	IN?	PRSO,HERE /?CTR17
?PRD30:	EQUAL?	PRSO,DB,WALDO \?PRD33
	EQUAL?	HERE,HOLD \?CTR17
?PRD33:	IN?	PRSO,WALDO \?PRD36
	EQUAL?	HERE,HOLD \?CTR17
?PRD36:	IN?	PRSO,FISH-TANK \?CCL18
?CTR17:	PRINTI	"water"
	JUMP	?CND12
?CCL18:	PRINTI	"dust"
?CND12:	PRINTR	" there."


	.FUNCT	V-LOWER:ANY:0:0
	CALL1	V-RAISE
	RSTACK	


	.FUNCT	V-MAP:ANY:0:0,TBL,RM,RM-ICON,CX,CY,CHAR
	ZERO?	DEBUG /?CND1
	FIRST?	ROOMS >RM /?PRG4
?PRG4:	ZERO?	RM /?REP5
	FSET	RM,TOUCHBIT
	NEXT?	RM >RM /?PRG4
	JUMP	?PRG4
?REP5:	SET	'BEEN-IN-FR-UPPER-FLOORS,TRUE-VALUE
?CND1:	ZERO?	DEMO-VERSION? /?CCL11
	ICALL1	NOT-IN-DEMO
	RETURN	2
?CCL11:	CALL1	DO-MAP
	EQUAL?	STACK,M-FATAL \?CND9
	RETURN	2
?CND9:	GETP	HERE,P?MAP-LOC >TBL
	GET	TBL,1
	CALL2	MAP-Y,STACK >CY
	GET	TBL,2
	CALL2	MAP-X,STACK >CX
?PRG17:	ISAVE	
	EQUAL?	2,STACK \?CND19
	ICALL1	V-$REFRESH
?CND19:	GETP	HERE,P?ICON >RM-ICON
	ZERO?	RM-ICON /?CCL23
	PUSH	RM-ICON
	JUMP	?CND21
?CCL23:	PUSH	ICONLESS-ROOM-BOX
?CND21:	CALL	BLINK,STACK,YOU-ARE-HERE-SYMBOL,CY,CX,S-FULL >CHAR
	EQUAL?	CHAR,CLICK1,CLICK2 \?REP18
	CALL1	MAP-CLICK
	ZERO?	STACK /?CND27
	SET	'ROSE-NEEDS-UPDATING,TRUE-VALUE
	EQUAL?	CURRENT-SPLIT,MAP-TOP-LEFT-LOC \?REP18
	FSET?	HERE,DELTABIT \?CCL33
	ICALL1	RETURN-FROM-MAP
	JUMP	?REP18
?CCL33:	ZERO?	CHANGE-MAP /?CND29
	ICALL1	DO-MAP
?CND29:	GETP	HERE,P?MAP-LOC >TBL
	GET	TBL,1
	CALL2	MAP-Y,STACK >CY
	GET	TBL,2
	CALL2	MAP-X,STACK >CX
?CND27:	EQUAL?	CURRENT-SPLIT,MAP-TOP-LEFT-LOC /?PRG17
?REP18:	CALL1	RETURN-FROM-MAP
	RSTACK	


	.FUNCT	DO-MAP:ANY:0:0,TBL,MAP-NUM,RM,RM-ICON,BIT,?TMP1
	SET	'BIT,64
	SET	'CHANGE-MAP,FALSE-VALUE
	EQUAL?	HERE,GONDOLA \?CCL3
	GETP	HERE,P?MAP-LOC
	GET	STACK,0
	EQUAL?	STACK,FALSE-VALUE \?CCL3
	PRINTI	"[Mapping is temporarily unavailable.]"
	CRLF	
	RETURN	2
?CCL3:	GETP	HERE,P?MAP-LOC
	ZERO?	STACK \?CCL9
	PRINTI	"[No on-screen map is available for this location."
	EQUAL?	HERE,CONSTRUCTION \?CND10
	PRINTI	" Use the blueprint from your package."
?CND10:	PRINTC	93
	CRLF	
	RETURN	2
?CCL9:	FSET?	HERE,DELTABIT /?PRD17
	EQUAL?	HERE,RIVERS-END,OCEANS-EDGE \?CCL15
?PRD17:	ZERO?	CHANGED-MAP-WARNING \?CCL15
	SET	'CHANGED-MAP-WARNING,TRUE-VALUE
	PRINTI	"The jester "
	IN?	JESTER,HERE /?CND20
	PRINTI	"appears for a moment and "
?CND20:	PRINTI	"says, ""It may seem odd and it may seem queer, but on-screen mapping works differently here."""
	CRLF	
	CRLF	
	ICALL1	HIT-ANY-KEY
	JUMP	?CND1
?CCL15:	ZERO?	MAP-NOTE \?CND1
	SET	'MAP-NOTE,TRUE-VALUE
	PRINTI	"Please read the section in the manual on on-screen mapping, if you have not already done so. Are you ready to see the map (y or n)? >"
	CALL1	Y?
	ZERO?	STACK \?CND1
	RETURN	2
?CND1:	PICINF	MAP-BOX-SIZE,PICINF-TBL /?BOGUS27
?BOGUS27:	GET	PICINF-TBL,1 >MAP-BOX-WIDTH
	GET	PICINF-TBL,0 >MAP-BOX-HEIGHT
	PICINF	MAP-SPACE-SIZE,PICINF-TBL /?BOGUS28
?BOGUS28:	GET	PICINF-TBL,1 >MAP-SPACE-WIDTH
	GET	PICINF-TBL,0 >MAP-SPACE-HEIGHT
	ICALL2	PICINF-PLUS-ONE,MAP-TOP-LEFT-LOC
	GET	PICINF-TBL,1 >MAP-TOP-LEFT-X
	GET	PICINF-TBL,0 >MAP-TOP-LEFT-Y
	PICINF	MAP-BASIC-ELT-SIZE,PICINF-TBL /?BOGUS29
?BOGUS29:	GET	PICINF-TBL,1 >MAP-ELEMENT-WIDTH
	GET	PICINF-TBL,0 >MAP-ELEMENT-HEIGHT
	GETP	HERE,P?MAP-LOC >TBL
	GET	TBL,0 >MAP-NUM
	FIRST?	ROOMS >RM /?BOGUS30
?BOGUS30:	CALL1	APPLE?
	ZERO?	STACK /?CND31
	ICALL2	FORCE-DISK-FLIP,MAP-NUM
?CND31:	CLEAR	-1
	SCREEN	S-FULL
	SET	'CURRENT-SPLIT,MAP-TOP-LEFT-LOC
	CURSET	-1
	DISPLAY	MAP-BORDER,1,1
	ICALL2	MODIFY-PICSET-TBL,MAP-NUM
	PICSET	MAP-PICSET-TBL
	ICALL2	DRAW-TITLES,MAP-NUM
?PRG33:	ZERO?	RM /?PRG58
	GETP	RM,P?MAP-LOC >TBL
	ZERO?	TBL /?CND37
	GET	TBL,0
	EQUAL?	STACK,MAP-NUM \?CND37
	FSET?	RM,TOUCHBIT /?CCL40
	EQUAL?	HERE,RM /?CCL40
	EQUAL?	RM,FR-OFFICES,OFFICES-NORTH,OFFICES-SOUTH /?PRD47
	EQUAL?	RM,OFFICES-EAST,OFFICES-WEST \?CND37
?PRD47:	ZERO?	BEEN-IN-FR-UPPER-FLOORS /?CND37
?CCL40:	FSET?	RM,DELTABIT \?CCL52
	FIRST?	RM \?CND37
?CCL52:	GETP	RM,P?ICON >RM-ICON
	ZERO?	RM-ICON /?CCL56
	GET	TBL,1 >?TMP1
	GET	TBL,2
	ICALL	DISPLAY-ROOM,RM-ICON,?TMP1,STACK
	ICALL	DRAW-CONS,RM,TBL
	JUMP	?CND37
?CCL56:	GET	TBL,1 >?TMP1
	GET	TBL,2
	ICALL	DISPLAY-ROOM,ICONLESS-ROOM-BOX,?TMP1,STACK
	ICALL	DRAW-CONS,RM,TBL
?CND37:	NEXT?	RM >RM /?PRG33
	JUMP	?PRG33
?PRG58:	DLESS?	'BIT,LOW-DIRECTION /?REP59
	SUB	64,BIT
	FCLEAR	ROOMS,STACK
	JUMP	?PRG58
?REP59:	ICALL2	PICINF-PLUS-ONE,MAP-ROSE-LOC
	GET	PICINF-TBL,0 >?TMP1
	GET	PICINF-TBL,1
	DISPLAY	MAP-ROSE-BG,?TMP1,STACK
	CALL1	UPDATE-MAP-ROSE
	RSTACK	


	.FUNCT	FORCE-DISK-FLIP:ANY:1:1,MAP-NUM
	EQUAL?	MAP-NUM,MAIN-MAP-NUM \?CCL3
	PUSH	CASTLE-SEGMENT-PIC
	JUMP	?CND1
?CCL3:	EQUAL?	MAP-NUM,SECRET-WING-MAP-NUM \?CCL5
	PUSH	SECRET-SEGMENT-PIC
	JUMP	?CND1
?CCL5:	EQUAL?	MAP-NUM,VILLAGE-MAP-NUM \?CCL7
	PUSH	VILLAGE-SEGMENT-PIC
	JUMP	?CND1
?CCL7:	EQUAL?	MAP-NUM,LOWER-LEVEL-MAP-NUM \?CCL9
	PUSH	LOWER-SEGMENT-PIC
	JUMP	?CND1
?CCL9:	EQUAL?	MAP-NUM,LAKE-MAP-NUM \?CCL11
	PUSH	LAKE-SEGMENT-PIC
	JUMP	?CND1
?CCL11:	EQUAL?	MAP-NUM,DESERT-MAP-NUM \?CCL13
	PUSH	LAKE-SEGMENT-PIC
	JUMP	?CND1
?CCL13:	EQUAL?	MAP-NUM,FOOZLE-MAP-NUM \?CCL15
	PUSH	FOOZLE-SEGMENT-PIC
	JUMP	?CND1
?CCL15:	EQUAL?	MAP-NUM,FENSHIRE-MAP-NUM \?CCL17
	PUSH	FENSHIRE-SEGMENT-PIC
	JUMP	?CND1
?CCL17:	PUSH	ORACLE-SEGMENT-PIC
?CND1:	PICINF	STACK,PICINF-TBL /TRUE
	RFALSE	


	.FUNCT	UPDATE-MAP-ROSE:ANY:0:0
	SET	'ROSE-NEEDS-UPDATING,FALSE-VALUE
	ICALL2	PICINF-PLUS-ONE,MAP-COMPASS-PIC-LOC
	ICALL	DRAW-COMPASS-ROSE,P?NORTH,MAP-N-HL,MAP-N-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?NE,MAP-NE-HL,MAP-NE-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?EAST,MAP-E-HL,MAP-E-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?SE,MAP-SE-HL,MAP-SE-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?SOUTH,MAP-S-HL,MAP-S-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?SW,MAP-SW-HL,MAP-SW-UNHL,TRUE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?WEST,MAP-W-HL,MAP-W-UNHL,TRUE-VALUE
	CALL	DRAW-COMPASS-ROSE,P?NW,MAP-NW-HL,MAP-NW-UNHL,TRUE-VALUE
	RSTACK	


	.FUNCT	MODIFY-PICSET-TBL:ANY:1:1,MAP-NUM,TBL,?TMP1
