?CCL80:	DIV	MAP-BOX-HEIGHT,2
	SUB	STACK,1
	ICALL	DISPLAY-ROOM,DELTA-1-3-CON,MAP-GEN-Y-3,MAP-GEN-X-8,STACK,MAP-BOX-WIDTH
?CND74:	FIRST?	DELTA-1 \?CND81
	FIRST?	DELTA-4 \?CND81
	ICALL	DISPLAY-ROOM,DELTA-1-4-CON,MAP-GEN-Y-2,MAP-GEN-X-9,0,MAP-BOX-WIDTH
