	.FUNCT	BONES-F:ANY:0:0
	CALL2	TOUCHING?,BONES
	ZERO?	STACK /FALSE
	PRINTR	"Let the dead lie in peace."


	.FUNCT	CLEAR-BORDER:ANY:0:0,X,Y,WRD,?TMP1
	SCREEN	S-WINDOW
	COLOR	FG-COLOR,BG-COLOR
	ICALL2	PICINF-PLUS-ONE,TEXT-WINDOW-PIC-LOC
	GET	PICINF-TBL,0 >Y
	GET	PICINF-TBL,1 >X
	WINPOS	S-WINDOW,1,1
	GET	0,17
	WINSIZE	S-WINDOW,Y,STACK
	CLEAR	1
	GRTR?	X,1 \?CND1
	ADD	Y,1
	WINPOS	S-WINDOW,STACK,1
	GET	0,18
	SUB	STACK,Y >?TMP1
	SUB	X,1
	WINSIZE	S-WINDOW,?TMP1,STACK
	CLEAR	1
	ADD	Y,1 >?TMP1
	GET	0,17
	SUB	STACK,X
	ADD	STACK,1
	WINPOS	S-WINDOW,?TMP1,STACK
	GET	0,18
	SUB	STACK,Y
	WINSIZE	S-WINDOW,STACK,X
	CLEAR	1
?CND1:	SET	'SL-SCORE,-1
	SET	'OLD-REGION,FALSE-VALUE
	SET	'OLD-HERE,FALSE-VALUE
	SET	'COMPASS-CHANGED,TRUE-VALUE
	COLOR	DEFAULT-FG,DEFAULT-BG
	SCREEN	S-TEXT
	RTRUE	


	.FUNCT	ADJUST-TEXT-WINDOW:ANY:1:1,ID,SCRY,WINY,ADJ
	GET	0,18 >SCRY
	ZERO?	ID /?CND1
	PICINF	ID,PICINF-TBL /?BOGUS3
?BOGUS3:	GET	PICINF-TBL,0 >ADJ
?CND1:	WINGET	S-TEXT,WTOP
	SUB	STACK,1
	SUB	SCRY,STACK
	SUB	STACK,ADJ >WINY
	DIV	WINY,FONT-Y
	MUL	FONT-Y,STACK >WINY
	WINGET	S-TEXT,WWIDE
	WINSIZE	S-TEXT,WINY,STACK
	RTRUE	


	.FUNCT	SPLIT-BY-PICTURE:ANY:1:2,ID,CLEAR-SCREEN?,Y,X,YS,XS,?TMP2,?TMP1
	SET	'CURRENT-SPLIT,ID
	ZERO?	CLEAR-SCREEN? /?CND1
	CLEAR	-1
?CND1:	PICINF	ID,PICINF-TBL /?BOGUS3
?BOGUS3:	GET	PICINF-TBL,0 >Y
	ADD	Y,1 >?TMP1
	ZERO?	BORDER-ON \?CCL6
	EQUAL?	ID,TEXT-WINDOW-PIC-LOC \?CCL6
	PUSH	1
	JUMP	?CND4
?CCL6:	GET	PICINF-TBL,1 >X
	ADD	X,1
?CND4:	WINPOS	S-TEXT,?TMP1,STACK
	GET	0,18
	SUB	STACK,Y >?TMP1
	ZERO?	BORDER-ON \?CCL11
	EQUAL?	ID,TEXT-WINDOW-PIC-LOC \?CCL11
	MUL	WIDTH,FONT-X
	JUMP	?CND9
?CCL11:	GET	0,17 >?TMP2
	MUL	X,2
	SUB	?TMP2,STACK
?CND9:	WINSIZE	S-TEXT,?TMP1,STACK
	WINPOS	S-WINDOW,1,1
	GET	0,17
	WINSIZE	S-WINDOW,Y,STACK
	RTRUE	


	.FUNCT	INIT-SL-WITH-SPLIT:ANY:1:2,WHICH,DONT-CLEAR,YFUDGE
	ZERO?	WHICH /?CND1
	SET	'CURRENT-SPLIT,WHICH
?CND1:	CALL2	INIT-STATUS-LINE,DONT-CLEAR
	RSTACK	


	.FUNCT	INIT-STATUS-LINE:ANY:0:1,DONT-CLEAR,NUM,X,Y,BIT,?TMP2,?TMP1
	SET	'NUM,1
	SET	'BIT,64
	SET	'OLD-HERE,FALSE-VALUE
	SET	'OLD-REGION,FALSE-VALUE
	SET	'SL-SCORE,-1
	SET	'COMPASS-CHANGED,TRUE-VALUE
	SET	'NEW-COMPASS,TRUE-VALUE
	ZERO?	DONT-CLEAR \?CND1
	CLEAR	-1
?CND1:	ICALL2	SPLIT-BY-PICTURE,CURRENT-SPLIT
	EQUAL?	CURRENT-SPLIT,TEXT-WINDOW-PIC-LOC \?CCL5
	ICALL2	ADJUST-TEXT-WINDOW,0
	ZERO?	BORDER-ON /?CCL10
	SCREEN	S-FULL
	CALL1	SET-BORDER >CURRENT-BORDER
	ICALL2	DISPLAY-BORDER,CURRENT-BORDER
	PICSET	COMPASS-PICSET-TBL
?PRG11:	DLESS?	'BIT,LOW-DIRECTION /?REP12
	SUB	64,BIT
	FCLEAR	ROOMS,STACK
	JUMP	?PRG11
?CCL5:	EQUAL?	CURRENT-SPLIT,F-SPLIT \?CCL7
	ICALL2	ADJUST-TEXT-WINDOW,F-BOTTOM
	RTRUE	
?CCL7:	ICALL2	ADJUST-TEXT-WINDOW,PBOZ-BOTTOM
	RTRUE	
?REP12:	SCREEN	S-WINDOW
	JUMP	?CND8
?CCL10:	SCREEN	S-WINDOW
	ICALL2	INVERSE-LINE,1
	ICALL2	INVERSE-LINE,2
	ICALL2	INVERSE-LINE,3
?CND8:	FONT	4
	GETB	0,39 >FONT-X
	GET	SL-LOC-TBL,0
	ADD	STACK,FONT-Y >?TMP1
	GET	SL-LOC-TBL,1
	CURSET	?TMP1,STACK
	GETB	0,30
	EQUAL?	STACK,IBM \?CCL18
	GET	0,8
	BTST	STACK,64 /?CCL18
	HLIGHT	H-INVERSE
	JUMP	?CND16
?CCL18:	ZERO?	BORDER-ON /?CCL22
	COLOR	DEFAULT-FG,-1
	JUMP	?CND16
?CCL22:	HLIGHT	H-INVERSE
?CND16:	PRINTI	"Moves:"
	GET	SL-LOC-TBL,2
	ADD	STACK,FONT-Y >?TMP1
	GET	SL-LOC-TBL,3 >?TMP2
	MUL	FONT-X,10
	SUB	?TMP2,STACK
	CURSET	?TMP1,STACK
	PRINTI	"Score:"
	GETB	0,30
	EQUAL?	STACK,IBM \?CCL25
	GET	0,8
	BTST	STACK,64 /?CCL25
	HLIGHT	H-NORMAL
	JUMP	?CND23
?CCL25:	ZERO?	BORDER-ON /?CCL29
	COLOR	DEFAULT-FG,DEFAULT-BG
	JUMP	?CND23
?CCL29:	HLIGHT	H-NORMAL
?CND23:	FONT	1
	SCREEN	S-TEXT
	RFALSE	

	.SEGMENT "HINTS"


	.FUNCT	DISPLAY-BORDER:ANY:1:1,B,BL,BR,Y,X,?TMP1
	SET	'NEW-COMPASS,TRUE-VALUE
	DISPLAY	B,1,1
	PICINF	B,PICINF-TBL /?BOGUS1
?BOGUS1:	GET	PICINF-TBL,0 >Y
	GET	PICINF-TBL,1 >X
	EQUAL?	B,OUTSIDE-BORDER \?CCL4
	SET	'BL,OUTSIDE-BORDER-L
	SET	'BR,OUTSIDE-BORDER-R
	JUMP	?CND2
?CCL4:	EQUAL?	B,CASTLE-BORDER \?CCL6
	SET	'BL,CASTLE-BORDER-L
	SET	'BR,CASTLE-BORDER-R
	JUMP	?CND2
?CCL6:	EQUAL?	B,UNDERGROUND-BORDER \?CCL8
	SET	'BL,UNDERGROUND-BORDER-L
	SET	'BR,UNDERGROUND-BORDER-R
	JUMP	?CND2
?CCL8:	EQUAL?	B,HINT-BORDER \?CND2
	SET	'BL,HINT-BORDER-L
	SET	'BR,HINT-BORDER-R
?CND2:	PICINF	BL,PICINF-TBL \?CND10
	ADD	1,Y
	DISPLAY	BL,STACK,1
?CND10:	PICINF	BR,PICINF-TBL /?CCL13
	RETURN	B
?CCL13:	ADD	1,Y >?TMP1
	GET	PICINF-TBL,1
	SUB	X,STACK
	ADD	1,STACK
	DISPLAY	BR,?TMP1,STACK
	RETURN	B

	.ENDSEG

	.SEGMENT "0"


	.FUNCT	SET-BORDER:ANY:0:0
	EQUAL?	HERE,GONDOLA \?CCL3
	GRTR?	DIRIGIBLE-COUNTER,0 \?CCL3
	RETURN	OUTSIDE-BORDER
?CCL3:	EQUAL?	HERE,FORMAL-GARDEN,COURTYARD \?CCL7
	RETURN	CASTLE-BORDER
?CCL7:	EQUAL?	HERE,BARBICAN,UPPER-BARBICAN,GARRISON \?CCL9
	RETURN	OUTSIDE-BORDER
?CCL9:	FSET?	HERE,OUTSIDEBIT \?CCL11
	RETURN	OUTSIDE-BORDER
?CCL11:	FSET?	HERE,UNDERGROUNDBIT /?CTR12
	RETURN	CASTLE-BORDER
?CTR12:	RETURN	UNDERGROUND-BORDER


	.FUNCT	BLANK-IT:ANY:2:2,TBL-SLOT,COLS,NCOLS,X,?TMP1
	LESS?	COLS,0 \?CND1
	SUB	0,COLS >NCOLS
?CND1:	GET	SL-LOC-TBL,TBL-SLOT >?TMP1
	MUL	FONT-X,NCOLS
	SUB	?TMP1,STACK >X
	SUB	TBL-SLOT,1
	GET	SL-LOC-TBL,STACK
	CURSET	STACK,X
	LESS?	COLS,0 \?CCL5
	SUB	0,COLS
	JUMP	?CND3
?CCL5:	PUSH	COLS
?CND3:	ICALL2	PRINT-SPACES,STACK
	RETURN	X


	.FUNCT	DRAW-NEW-HERE:ANY:0:0,X,?TMP1
	SET	'OLD-HERE,HERE
	GET	SL-LOC-TBL,0 >?TMP1
	ZERO?	NARROW? /?CCL3
	PUSH	18
	JUMP	?CND1
?CCL3:	PUSH	24
?CND1:	CALL	BLANK-IT,1,STACK
	CURSET	?TMP1,STACK
	ZERO?	NARROW? \?PRD8
	EQUAL?	HERE,PHIL-HALL \?CCL6
?PRD8:	GETP	HERE,P?APPLE-DESC >X
	ZERO?	X /?CCL6
	PRINT	X
	RTRUE	
?CCL6:	EQUAL?	HERE,G-U-MOUNTAIN,G-U-SAVANNAH,G-U-HIGHWAY \?CCL12
	PRINTI	"Great Undergd. "
	EQUAL?	HERE,G-U-MOUNTAIN \?CCL15
	PRINTI	"Mountain"
	RTRUE	
?CCL15:	EQUAL?	HERE,G-U-SAVANNAH \?CCL17
	PRINTI	"Savannah"
	RTRUE	
?CCL17:	PRINTI	"Highway"
	RTRUE	
?CCL12:	PRINTD	HERE
	RTRUE	


	.FUNCT	DRAW-NEW-REGION:ANY:0:0,?TMP2,?TMP1
	GETP	HERE,P?REGION >OLD-REGION
	DIROUT	D-TABLE-ON,SLINE
	PUT	SLINE,0,0
	PRINT	OLD-REGION
	DIROUT	D-TABLE-OFF
	ZERO?	NARROW? /?CCL3
	PUSH	-19
	JUMP	?CND1
?CCL3:	PUSH	-23
?CND1:	ICALL	BLANK-IT,3,STACK
	GET	SL-LOC-TBL,2 >?TMP1
	GET	SL-LOC-TBL,3 >?TMP2
	GET	SLINE,0
	MUL	FONT-X,STACK
	SUB	?TMP2,STACK
	CURSET	?TMP1,STACK
	PRINT	OLD-REGION
	RTRUE	


	.FUNCT	DRAW-NEW-SCORE:ANY:0:0,Y,X
	SET	'SL-SCORE,SCORE
	GET	SL-LOC-TBL,2
	ADD	STACK,FONT-Y >Y
	GET	SL-LOC-TBL,3 >X
	MUL	FONT-X,4
	SUB	X,STACK
	CURSET	Y,STACK
	ICALL2	PRINT-SPACES,4
	GRTR?	SCORE,999 /?CTR2
	LESS?	SCORE,-99 \?CCL3
?CTR2:	PUSH	4
	JUMP	?CND1
?CCL3:	GRTR?	SCORE,99 /?CTR6
	LESS?	SCORE,-9 \?CCL7
?CTR6:	PUSH	3
	JUMP	?CND1
?CCL7:	GRTR?	SCORE,9 /?CTR10
	LESS?	SCORE,0 \?CCL11
?CTR10:	PUSH	2
	JUMP	?CND1
?CCL11:	PUSH	1
?CND1:	MUL	FONT-X,STACK
	SUB	X,STACK
	CURSET	Y,STACK
	PRINTN	SCORE
	RTRUE	


	.FUNCT	DRAW-NEW-COMP:ANY:0:0,?TMP2,?TMP1
	SET	'COMPASS-CHANGED,FALSE-VALUE
	ICALL	DRAW-COMPASS-ROSE,P?NORTH,N-HL,N-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?NE,NE-HL,NE-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?EAST,E-HL,E-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?SE,SE-HL,SE-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?SOUTH,S-HL,S-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?SW,SW-HL,SW-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?WEST,W-HL,W-UNHL
	ICALL	DRAW-COMPASS-ROSE,P?NW,NW-HL,NW-UNHL
	ZERO?	LIT /?CCL3
	CALL	SHOW-DIRECTION?,HERE,P?UP,FALSE-VALUE
	ZERO?	STACK /?CCL3
	SUB	64,P?UP
	FSET?	ROOMS,STACK /?CND1
	SUB	64,P?UP
	FSET	ROOMS,STACK
	GET	SL-LOC-TBL,6 >?TMP1
	GET	SL-LOC-TBL,7
	DISPLAY	U-BOX,?TMP1,STACK
	JUMP	?CND1
?CCL3:	SUB	64,P?UP
	FSET?	ROOMS,STACK \?CND1
	SUB	64,P?UP
	FCLEAR	ROOMS,STACK
	EQUAL?	CURRENT-BORDER,CASTLE-BORDER \?CCL11
	SET	'?TMP2,CASTLE-BOX-COVER
	JUMP	?CND9
?CCL11:	EQUAL?	CURRENT-BORDER,OUTSIDE-BORDER \?CCL13
	SET	'?TMP2,OUTSIDE-BOX-COVER
	JUMP	?CND9
?CCL13:	SET	'?TMP2,UG-BOX-COVER
?CND9:	GET	SL-LOC-TBL,6 >?TMP1
	GET	SL-LOC-TBL,7
	DISPLAY	?TMP2,?TMP1,STACK
?CND1:	ZERO?	LIT /?CCL16
	CALL	SHOW-DIRECTION?,HERE,P?DOWN,FALSE-VALUE
	ZERO?	STACK /?CCL16
	ZERO?	NEW-COMPASS \?CCL20
	SUB	64,P?DOWN
	FSET?	ROOMS,STACK /?CND14
?CCL20:	SUB	64,P?DOWN
	FSET	ROOMS,STACK
	GET	SL-LOC-TBL,8 >?TMP1
	GET	SL-LOC-TBL,9
	DISPLAY	D-BOX,?TMP1,STACK
	JUMP	?CND14
?CCL16:	ZERO?	NEW-COMPASS \?CCL23
	SUB	64,P?DOWN
	FSET?	ROOMS,STACK \?CND14
?CCL23:	SUB	64,P?DOWN
	FCLEAR	ROOMS,STACK
	EQUAL?	CURRENT-BORDER,CASTLE-BORDER \?CCL28
	SET	'?TMP2,CASTLE-BOX-COVER
	JUMP	?CND26
?CCL28:	EQUAL?	CURRENT-BORDER,OUTSIDE-BORDER \?CCL30
	SET	'?TMP2,OUTSIDE-BOX-COVER
	JUMP	?CND26
?CCL30:	SET	'?TMP2,UG-BOX-COVER
?CND26:	GET	SL-LOC-TBL,8 >?TMP1
	GET	SL-LOC-TBL,9
	DISPLAY	?TMP2,?TMP1,STACK
?CND14:	SET	'NEW-COMPASS,FALSE-VALUE
	RETURN	NEW-COMPASS


	.FUNCT	DRAW-COMPASS-ROSE:ANY:3:4,DIR,HIGHLIGHT-PIC,UNHIGHLIGHT-PIC,MAPPING,BIT,X,Y
	SUB	64,DIR >BIT
	ZERO?	MAPPING /?CCL3
	GET	PICINF-TBL,0 >Y
	GET	PICINF-TBL,1 >X
	JUMP	?CND1
?CCL3:	GET	SL-LOC-TBL,4 >Y
	GET	SL-LOC-TBL,5 >X
?CND1:	ZERO?	LIT /?CCL6
	CALL	SHOW-DIRECTION?,HERE,DIR,FALSE-VALUE
	ZERO?	STACK /?CCL6
	ZERO?	NEW-COMPASS \?CCL11
	FSET?	ROOMS,BIT \FALSE
?CCL11:	FCLEAR	ROOMS,BIT
	DISPLAY	HIGHLIGHT-PIC,Y,X
	RTRUE	
?CCL6:	ZERO?	NEW-COMPASS \?CCL16
	FSET?	ROOMS,BIT /FALSE
?CCL16:	FSET	ROOMS,BIT
	DISPLAY	UNHIGHLIGHT-PIC,Y,X
	RTRUE	


	.FUNCT	SHOW-DIRECTION?:ANY:2:3,RM,DIR,MAPPING,PTS
	ASSIGNED?	'MAPPING /?CND1
	SET	'MAPPING,TRUE-VALUE
?CND1:	IN?	N-S-PASSAGE,RM \?CCL5
	EQUAL?	RM,CONSTRUCTION /?CCL5
	EQUAL?	N-S-PASSAGE-DIR,DIR /TRUE
?CCL5:	IN?	NW-SE-PASSAGE,RM \?CCL10
	EQUAL?	RM,CONSTRUCTION /?CCL10
	EQUAL?	NW-SE-PASSAGE-DIR,DIR /TRUE
?CCL10:	IN?	PROTAGONIST,YACHT \?CCL15
	EQUAL?	DIR,P?DOWN /TRUE
?CCL15:	EQUAL?	RM,INQUISITION \?CCL19
	EQUAL?	DIR,P?SOUTH /TRUE
?CCL19:	EQUAL?	RM,RUBBLE-ROOM \?CCL23
	EQUAL?	DIR,P?NORTH,P?EAST \?CCL23
	FSET?	RUBBLE-ROOM,TOUCHBIT \?CCL23
	FSET?	HEART-OF-MINE,TOUCHBIT /FALSE
?CCL23:	EQUAL?	RM,HEART-OF-MINE \?CCL29
	EQUAL?	DIR,P?WEST,P?SOUTH \?CCL29
	FSET?	RUBBLE-ROOM,TOUCHBIT \?CCL29
	FSET?	HEART-OF-MINE,TOUCHBIT /FALSE
?CCL29:	FSET?	RM,DELTABIT \?CCL35
	EQUAL?	DIR,P?UP,P?DOWN /FALSE
	EQUAL?	RM,DELTA-1 \TRUE
	EQUAL?	DIR,P?SOUTH \TRUE
	ZERO?	MAPPING \FALSE
	RTRUE	
?CCL35:	EQUAL?	RM,CONSTRUCTION \?CCL45
	EQUAL?	DIR,P?UP,P?DOWN /FALSE
	EQUAL?	DIR,P?NORTH \?PRD52
	INTBL?	CONSTRUCTION-LOC,NORTH-EXITS,11 /TRUE
?PRD52:	EQUAL?	DIR,P?NE \?PRD55
	INTBL?	CONSTRUCTION-LOC,NE-EXITS,17 /TRUE
?PRD55:	EQUAL?	DIR,P?EAST \?PRD58
	INTBL?	CONSTRUCTION-LOC,EAST-EXITS,15 /TRUE
?PRD58:	EQUAL?	DIR,P?SE \?PRD61
	INTBL?	CONSTRUCTION-LOC,SE-EXITS,7 /TRUE
?PRD61:	EQUAL?	DIR,P?SOUTH \?PRD64
	ADD	CONSTRUCTION-LOC,8
	INTBL?	STACK,NORTH-EXITS,11 /TRUE
?PRD64:	EQUAL?	DIR,P?SW \?PRD67
	ADD	CONSTRUCTION-LOC,7
	INTBL?	STACK,NE-EXITS,17 /TRUE
?PRD67:	EQUAL?	DIR,P?WEST \?PRD70
	SUB	CONSTRUCTION-LOC,1
	INTBL?	STACK,EAST-EXITS,15 /TRUE
?PRD70:	EQUAL?	DIR,P?NW \?PRD73
	SUB	CONSTRUCTION-LOC,9
	INTBL?	STACK,SE-EXITS,7 /TRUE
?PRD73:	EQUAL?	DIR,P?EAST \?CCL50
	EQUAL?	CONSTRUCTION-LOC,47 /TRUE
?CCL50:	IN?	N-S-PASSAGE,RM \?CCL79
	FSET?	N-S-PASSAGE,TAKEBIT /?CCL79
	EQUAL?	DIR,P?NORTH,P?SOUTH \?CCL79
	EQUAL?	CONSTRUCTION-LOC,N-S-PASSAGE-LOC \?CCL85
	EQUAL?	N-S-PASSAGE-DIR,DIR /TRUE
?CCL85:	EQUAL?	CONSTRUCTION-LOC,N-S-PASSAGE-LOC /FALSE
	EQUAL?	N-S-PASSAGE-DIR,DIR /FALSE
	RTRUE	
?CCL79:	IN?	NW-SE-PASSAGE,RM \FALSE
	FSET?	NW-SE-PASSAGE,TAKEBIT /FALSE
	EQUAL?	DIR,P?NW,P?SE \FALSE
	EQUAL?	CONSTRUCTION-LOC,NW-SE-PASSAGE-LOC \?CCL99
	EQUAL?	NW-SE-PASSAGE-DIR,DIR /TRUE
?CCL99:	EQUAL?	CONSTRUCTION-LOC,NW-SE-PASSAGE-LOC /FALSE
	EQUAL?	NW-SE-PASSAGE-DIR,DIR /FALSE
	RTRUE	
?CCL45:	EQUAL?	RM,PLAIN \?CCL107
	EQUAL?	DIR,P?UP,P?DOWN /FALSE
	EQUAL?	DIR,P?NORTH,P?NE,P?NW \?PRD114
	EQUAL?	RANK,1 /FALSE
?PRD114:	EQUAL?	DIR,P?EAST,P?NE,P?SE \?PRD117
	EQUAL?	FILE,8 /FALSE
?PRD117:	EQUAL?	DIR,P?SOUTH,P?SE,P?SW \?PRD120
	EQUAL?	RANK,8 /FALSE
?PRD120:	EQUAL?	DIR,P?WEST,P?SW,P?NW \TRUE
	EQUAL?	FILE,1 /FALSE
	RTRUE	
?CCL107:	EQUAL?	RM,MIRROR-LAKE \?CCL126
	EQUAL?	DIR,P?NORTH,P?SOUTH,P?EAST /TRUE
	EQUAL?	DIR,P?WEST /TRUE
?CCL126:	EQUAL?	RM,WISHYFOO-TERRITORY \?CCL132
	EQUAL?	DIR,P?SW \?CCL132
	ZERO?	MAPPING /TRUE
?CCL132:	EQUAL?	RM,STREAM \?CCL137
	EQUAL?	DIR,P?WEST \?CCL137
	IN?	BRIDGE,STREAM \FALSE
?CCL137:	GETPT	RM,DIR >PTS
	ZERO?	PTS /FALSE
	PTSIZE	PTS
	EQUAL?	STACK,NEXIT /FALSE
	EQUAL?	RM,THRONE-ROOM \?CCL147
	EQUAL?	DIR,P?SOUTH \?CCL147
	ZERO?	SECRET-PASSAGE-OPEN /FALSE
?CCL147:	EQUAL?	RM,G-U-MOUNTAIN \?CCL152
	EQUAL?	DIR,P?NORTH \?CCL152
	IN?	BOULDER,RM /FALSE
?CCL152:	EQUAL?	RM,HOLLOW \?CCL157
	EQUAL?	DIR,P?SOUTH \?CCL157
	ZERO?	IRON-MINE-OPEN /FALSE
?CCL157:	EQUAL?	RM,PEG-ROOM \?CCL162
	EQUAL?	DIR,P?NORTH \?CCL162
	ZERO?	PEG-PASSAGE-OPENED /FALSE
?CCL162:	EQUAL?	RM,CRYPT \?CCL167
	EQUAL?	DIR,P?DOWN \?CCL167
	ZERO?	SEEN-HOLEY-SLAB /FALSE
?CCL167:	EQUAL?	RM,RUINED-HALL \?CCL172
	EQUAL?	DIR,P?EAST \?CCL172
	ZERO?	SECRET-ROOM-REVEALED /FALSE
?CCL172:	EQUAL?	RM,MARSH \?CCL177
	EQUAL?	DIR,P?NORTH \?CCL177
	ZERO?	STEPPING-STONES-VISIBLE /FALSE
?CCL177:	EQUAL?	RM,WEIRD \?CCL182
	EQUAL?	DIR,P?NORTH,P?EAST,P?WEST \?CCL182
	EQUAL?	DIR,P?NORTH \?CCL187
	EQUAL?	TOWER-BEATEN,PYRAMID /TRUE
	FSET?	PYRAMID,TOUCHBIT \FALSE
	ZERO?	MAPPING \TRUE
	RFALSE	
?CCL187:	EQUAL?	DIR,P?EAST \?CCL196
	EQUAL?	TOWER-BEATEN,PYRAMID-R /TRUE
	FSET?	PYRAMID-R,TOUCHBIT \FALSE
	ZERO?	MAPPING \TRUE
	RFALSE	
?CCL196:	EQUAL?	TOWER-BEATEN,PYRAMID-L /TRUE
	FSET?	PYRAMID-L,TOUCHBIT \FALSE
	ZERO?	MAPPING \TRUE
	RFALSE	
?CCL182:	ZERO?	MAPPING /TRUE
	EQUAL?	RM,COURTROOM \?CCL214
	EQUAL?	DIR,P?SOUTH /FALSE
?CCL214:	EQUAL?	RM,TAX-OFFICE \?CCL218
	EQUAL?	DIR,P?SOUTH /FALSE
?CCL218:	EQUAL?	RM,JESTERS-QUARTERS \?CCL222
	EQUAL?	DIR,P?SOUTH /FALSE
?CCL222:	EQUAL?	RM,BASE-OF-MOUNTAIN \?CCL226
	EQUAL?	DIR,P?EAST /FALSE
?CCL226:	EQUAL?	RM,G-U-MOUNTAIN \?CCL230
	EQUAL?	DIR,P?WEST /FALSE
?CCL230:	EQUAL?	RM,FOOTHILLS \?CCL234
	EQUAL?	DIR,P?SOUTH /FALSE
?CCL234:	EQUAL?	RM,BASE-OF-MOUNTAINS \TRUE
	EQUAL?	DIR,P?NORTH /FALSE
	RTRUE	


	.FUNCT	COMPASS-CLICK:ANY:2:2,PIC1,PIC2,TL-X,TL-Y,BR-X,BR-Y,CENTER-X,CENTER-Y,DIR
	EQUAL?	PIC1,COMPASS-PIC-LOC \?CND1
	GET	SL-LOC-TBL,7 >TL-X
	GET	SL-LOC-TBL,6 >TL-Y
	PICINF	U-BOX,PICINF-TBL /?BOGUS3
?BOGUS3:	GET	PICINF-TBL,1
	ADD	TL-X,STACK >BR-X
	GET	PICINF-TBL,0
	ADD	TL-Y,STACK >BR-Y
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND4
	RETURN	P?UP
?CND4:	GET	SL-LOC-TBL,9 >TL-X
	GET	SL-LOC-TBL,8 >TL-Y
	PICINF	D-BOX,PICINF-TBL /?BOGUS6
?BOGUS6:	GET	PICINF-TBL,1
	ADD	TL-X,STACK >BR-X
	GET	PICINF-TBL,0
	ADD	TL-Y,STACK >BR-Y
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CND1
	RETURN	P?DOWN
?CND1:	EQUAL?	PIC1,MAP-COMPASS-PIC-LOC \?CCL11
	ICALL2	PICINF-PLUS-ONE,PIC1
	GET	PICINF-TBL,0 >TL-Y
	GET	PICINF-TBL,1 >TL-X
	JUMP	?CND9
?CCL11:	GET	SL-LOC-TBL,4 >TL-Y
	GET	SL-LOC-TBL,5 >TL-X
?CND9:	PICINF	PIC2,PICINF-TBL /?BOGUS12
?BOGUS12:	GET	PICINF-TBL,0
	ADD	STACK,TL-Y >BR-Y
	GET	PICINF-TBL,1
	ADD	STACK,TL-X >BR-X
	GET	PICINF-TBL,1
	DIV	STACK,2
	ADD	TL-X,STACK >CENTER-X
	GET	PICINF-TBL,0
	DIV	STACK,2
	ADD	TL-Y,STACK >CENTER-Y
	CALL	WITHIN?,TL-X,TL-Y,BR-X,BR-Y
	ZERO?	STACK /?CCL15
	GETB	0,30
	EQUAL?	STACK,MACINTOSH \?CCL18
	CALL1	MAC-II?
	ZERO?	STACK \?CCL18
	CALL	MAC-CLICK,CENTER-X,CENTER-Y,TL-X,TL-Y >DIR
	JUMP	?CND16
?CCL18:	GETB	0,30
	EQUAL?	STACK,IBM,AMIGA,MACINTOSH /?CTR21
	CALL1	APPLE?
	ZERO?	STACK /?CCL22
?CTR21:	CALL	MAC-II-CLICK,CENTER-X,CENTER-Y >DIR
?CND16:	ZERO?	DIR /?CCL27
	RETURN	DIR
?CCL22:	SOUND	1
	PRINTI	"[Clicking on the compass rose is not yet implemented on this machine.]"
	CRLF	
	RFALSE	
?CCL27:	SOUND	1
	RFALSE	
?CCL15:	SOUND	1
	RFALSE	


	.FUNCT	MAC-CLICK:ANY:4:4,CENTER-X,CENTER-Y,TL-X,TL-Y,X,Y,DIR,?TMP3,?TMP1,?TMP2
	ADD	TL-X,25 >?TMP2
	ADD	TL-X,35 >?TMP1
	ADD	TL-Y,20
	CALL	WITHIN?,?TMP2,TL-Y,?TMP1,STACK
	ZERO?	STACK /?CCL3
	SET	'DIR,P?NORTH
	RETURN	DIR
?CCL3:	ADD	TL-X,25 >?TMP3
	ADD	TL-Y,36 >?TMP2
	ADD	TL-X,35 >?TMP1
	ADD	TL-Y,58
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL5
	SET	'DIR,P?SOUTH
	RETURN	DIR
?CCL5:	ADD	TL-X,38 >?TMP3
	ADD	TL-Y,23 >?TMP2
	ADD	TL-X,60 >?TMP1
	ADD	TL-Y,33
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL7
	SET	'DIR,P?EAST
	RETURN	DIR
?CCL7:	ADD	TL-Y,23 >?TMP2
	ADD	TL-X,22 >?TMP1
	ADD	TL-Y,33
	CALL	WITHIN?,TL-X,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL9
	SET	'DIR,P?WEST
	RETURN	DIR
?CCL9:	ADD	TL-X,37 >?TMP3
	ADD	TL-Y,10 >?TMP2
	ADD	TL-X,48 >?TMP1
	ADD	TL-Y,21
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL11
	SET	'DIR,P?NE
	RETURN	DIR
?CCL11:	ADD	TL-X,37 >?TMP3
	ADD	TL-Y,35 >?TMP2
	ADD	TL-X,48 >?TMP1
	ADD	TL-Y,46
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL13
	SET	'DIR,P?SE
	RETURN	DIR
?CCL13:	ADD	TL-X,12 >?TMP3
	ADD	TL-Y,35 >?TMP2
	ADD	TL-X,23 >?TMP1
	ADD	TL-Y,46
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL15
	SET	'DIR,P?SW
	RETURN	DIR
?CCL15:	ADD	TL-X,12 >?TMP3
	ADD	TL-Y,10 >?TMP2
	ADD	TL-X,23 >?TMP1
	ADD	TL-Y,21
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /?CCL17
	SET	'DIR,P?NW
	RETURN	DIR
?CCL17:	ADD	TL-X,23 >?TMP3
	ADD	TL-Y,21 >?TMP2
	ADD	TL-X,37 >?TMP1
	ADD	TL-Y,35
	CALL	WITHIN?,?TMP3,?TMP2,?TMP1,STACK
	ZERO?	STACK /FALSE
	GRTR?	MOUSE-LOC-X,CENTER-X \?CCL22
	LESS?	MOUSE-LOC-Y,CENTER-Y \?CCL22
	SUB	MOUSE-LOC-X,CENTER-X >X
	SUB	CENTER-Y,MOUSE-LOC-Y >Y
	GRTR?	X,Y \?CCL27
	SET	'DIR,P?EAST
	RETURN	DIR
?CCL27:	SET	'DIR,P?NORTH
	RETURN	DIR
?CCL22:	GRTR?	MOUSE-LOC-X,CENTER-X \?CCL29
	SUB	MOUSE-LOC-X,CENTER-X >X
	SUB	MOUSE-LOC-Y,CENTER-Y >Y
	GRTR?	X,Y \?CCL32
	SET	'DIR,P?EAST
	RETURN	DIR
?CCL32:	SET	'DIR,P?SOUTH
	RETURN	DIR
?CCL29:	GRTR?	MOUSE-LOC-Y,CENTER-Y \?CCL34
	SUB	CENTER-X,MOUSE-LOC-X >X
	SUB	MOUSE-LOC-Y,CENTER-Y >Y
	GRTR?	X,Y \?CCL37
	SET	'DIR,P?WEST
	RETURN	DIR
?CCL37:	SET	'DIR,P?SOUTH
	RETURN	DIR
?CCL34:	SUB	CENTER-X,MOUSE-LOC-X >X
	SUB	CENTER-Y,MOUSE-LOC-Y >Y
	GRTR?	X,Y \?CCL40
	SET	'DIR,P?WEST
	RETURN	DIR
?CCL40:	SET	'DIR,P?NORTH
	RETURN	DIR


	.FUNCT	MAC-II-CLICK:ANY:2:2,CENTER-X,CENTER-Y,X,Y,DIR,COMP-WIDTH,COMP-HEIGHT,?TMP1
	PICINF	N-HL,PICINF-TBL /?BOGUS1
?BOGUS1:	GET	PICINF-TBL,0 >COMP-HEIGHT
	GET	PICINF-TBL,1 >COMP-WIDTH
	GRTR?	MOUSE-LOC-X,CENTER-X \?CCL4
	LESS?	MOUSE-LOC-Y,CENTER-Y \?CCL4
	SUB	MOUSE-LOC-X,CENTER-X >X
	SUB	CENTER-Y,MOUSE-LOC-Y >Y
	MUL	Y,COMP-WIDTH
	DIV	STACK,COMP-HEIGHT >Y
	MUL	X,TANGENT-VALUE >?TMP1
	MUL	Y,100
	GRTR?	?TMP1,STACK \?CCL9
	SET	'DIR,P?EAST
	RETURN	DIR
?CCL9:	MUL	Y,TANGENT-VALUE >?TMP1
	MUL	X,100
	GRTR?	?TMP1,STACK \?CCL11
	SET	'DIR,P?NORTH
	RETURN	DIR
?CCL11:	SET	'DIR,P?NE
	RETURN	DIR
?CCL4:	GRTR?	MOUSE-LOC-X,CENTER-X \?CCL13
	SUB	MOUSE-LOC-X,CENTER-X >X
	SUB	MOUSE-LOC-Y,CENTER-Y >Y
	MUL	Y,COMP-WIDTH
	DIV	STACK,COMP-HEIGHT >Y
	MUL	X,TANGENT-VALUE >?TMP1
	MUL	Y,100
	GRTR?	?TMP1,STACK \?CCL16
	SET	'DIR,P?EAST
	RETURN	DIR
?CCL16:	MUL	Y,TANGENT-VALUE >?TMP1
	MUL	X,100
	GRTR?	?TMP1,STACK \?CCL18
	SET	'DIR,P?SOUTH
	RETURN	DIR
?CCL18:	SET	'DIR,P?SE
	RETURN	DIR
?CCL13:	GRTR?	MOUSE-LOC-Y,CENTER-Y \?CCL20
	SUB	CENTER-X,MOUSE-LOC-X >X
	SUB	MOUSE-LOC-Y,CENTER-Y >Y
	MUL	Y,COMP-WIDTH
	DIV	STACK,COMP-HEIGHT >Y
	MUL	X,TANGENT-VALUE >?TMP1
	MUL	Y,100
	GRTR?	?TMP1,STACK \?CCL23
	SET	'DIR,P?WEST
	RETURN	DIR
?CCL23:	MUL	Y,TANGENT-VALUE >?TMP1
	MUL	X,100
	GRTR?	?TMP1,STACK \?CCL25
	SET	'DIR,P?SOUTH
	RETURN	DIR
?CCL25:	SET	'DIR,P?SW
	RETURN	DIR
?CCL20:	SUB	CENTER-X,MOUSE-LOC-X >X
	SUB	CENTER-Y,MOUSE-LOC-Y >Y
	MUL	Y,COMP-WIDTH
	DIV	STACK,COMP-HEIGHT >Y
	MUL	X,TANGENT-VALUE >?TMP1
	MUL	Y,100
	GRTR?	?TMP1,STACK \?CCL28
	SET	'DIR,P?WEST
	RETURN	DIR
?CCL28:	MUL	Y,TANGENT-VALUE >?TMP1
	MUL	X,100
	GRTR?	?TMP1,STACK \?CCL30
	SET	'DIR,P?NORTH
	RETURN	DIR
?CCL30:	SET	'DIR,P?NW
	RETURN	DIR


	.FUNCT	SAY-HERE:ANY:0:0,X
	PRINTD	HERE
	LOC	PROTAGONIST >X
	IN?	PROTAGONIST,CARD-TABLE \?CCL3
	PRINTI	", at"
	ICALL2	TPRINT,X
	RTRUE	
?CCL3:	EQUAL?	X,HERE /?CCL5
	FSET?	X,VEHBIT \?CCL5
	PRINTI	", "
	FSET?	X,INBIT \?CCL10
	PRINTC	105
	JUMP	?CND8
?CCL10:	PRINTC	111
?CND8:	PRINTC	110
	ICALL2	TPRINT,X
	RTRUE	
?CCL5:	ZERO?	UNDER-TABLE /TRUE
	PRINTI	", under the table"
	RTRUE	


	.FUNCT	TOUCHING?:ANY:1:1,THING
	EQUAL?	PRSO,THING \?CCL3
	GET	TOUCHING-VERBS,0
	INTBL?	PRSA,TOUCHING-VERBS+2,STACK /TRUE
?CCL3:	EQUAL?	PRSI,THING \FALSE
	EQUAL?	PRSA,V?PUT-ON,V?PUT,V?GIVE /TRUE
	RFALSE	


	.FUNCT	HANDLE:ANY:1:1,OBJ
	EQUAL?	OBJ,PRSO \?PRD5
	CALL2	EVERYWHERE-VERB?,1
	ZERO?	STACK \FALSE
?PRD5:	EQUAL?	OBJ,PRSI \TRUE
	CALL2	EVERYWHERE-VERB?,2
	ZERO?	STACK /TRUE
	RFALSE	


	.FUNCT	CANT-SEE:ANY:0:2,OBJ,STRING,WRD
	CALL2	GET-NP,OBJ >WRD
	ZERO?	WRD /?CND1
	GET	WRD,2 >WRD
?CND1:	SET	'P-WON,FALSE-VALUE
	PRINTC	91
	PRINT	YOU-CANT
	PRINTI	"see"
	ZERO?	OBJ /?CCL4
	ZERO?	WRD /?CND3
	CALL2	CAPITAL-NOUN?,WRD
	ZERO?	STACK \?CND3
?CCL4:	PRINTI	" any"
?CND3:	ZERO?	OBJ \?CCL11
	PRINTC	32
	PRINT	STRING
	JUMP	?CND9
?CCL11:	EQUAL?	OBJ,PRSI \?CCL13
	ICALL1	PRSI-PRINT
	JUMP	?CND9
?CCL13:	ICALL1	PRSO-PRINT
?CND9:	PRINTI	" here.]"
	CRLF	
	CALL1	STOP
	RSTACK	


	.FUNCT	PRSO-PRINT:ANY:0:0,PTR
	CALL	NOUN-USED?,PRSO,W?IT
	ZERO?	STACK /?CCL3
	PRINTC	32
	CALL2	DPRINT,PRSO
	RSTACK	
?CCL3:	PRINTC	32
	CALL2	GET-NP,PRSO
	CALL2	NP-PRINT,STACK
	RSTACK	


	.FUNCT	PRSI-PRINT:ANY:0:0,PTR
	CALL	NOUN-USED?,PRSI,W?IT
	ZERO?	STACK /?CCL3
	PRINTC	32
	CALL2	DPRINT,PRSI
	RSTACK	
?CCL3:	PRINTC	32
	CALL2	GET-NP,PRSI
	CALL2	NP-PRINT,STACK
	RSTACK	


	.FUNCT	CANT-VERB-A-PRSO:ANY:1:1,STRING
	PRINT	YOU-CANT
	PRINT	STRING
	ICALL2	APRINT,PRSO
	PRINTR	"!"


	.FUNCT	TELL-HIT-HEAD:ANY:0:0
	PRINTI	"You hit your head against"
	ICALL1	TPRINT-PRSO
	PRINTR	" as you attempt this feat."


	.FUNCT	OPEN-CLOSED:ANY:1:1,OBJ
	FSET?	OBJ,OPENBIT \?CCL3
	PRINTI	"open"
	RTRUE	
?CCL3:	PRINTI	"closed"
	RTRUE	


	.FUNCT	CANT-REACH:ANY:1:1,OBJ
	ZERO?	HAND-IN-WALDO /?CCL3
	EQUAL?	OBJ,WALDO /?CCL3
	IN?	OBJ,HERE \?CCL3
	PRINTR	"The waldo doesn't seem capable of that."
?CCL3:	ZERO?	UNDER-TABLE /?CCL8
	PRINT	YOULL-HAVE-TO
	PRINTR	"get out from under the table in order to reach it."
?CCL8:	PRINT	YOU-CANT
	PRINTI	"reach"
	ICALL2	TPRINT,OBJ
	IN?	PROTAGONIST,HERE /?CND9
	PRINTI	" from"
	LOC	PROTAGONIST
	ICALL2	TPRINT,STACK
?CND9:	PRINT	PERIOD-CR
	RTRUE	


	.FUNCT	DO-FIRST:ANY:1:2,STRING,OBJ
	PRINT	YOULL-HAVE-TO
	PRINT	STRING
	ZERO?	OBJ /?CND1
	ICALL2	TPRINT,OBJ
?CND1:	PRINTR	" first."


	.FUNCT	NOT-IN:ANY:0:0
	PRINTI	"But"
	ICALL2	IS-ARE-PRINT,PRSO
	PRINTI	"not "
	FSET?	PRSI,ACTORBIT \?CCL3
	PRINTI	"being held by"
	JUMP	?CND1
?CCL3:	FSET?	PRSI,SURFACEBIT \?CCL5
	PRINTI	"on"
	JUMP	?CND1
?CCL5:	PRINTI	"in"
?CND1:	CALL2	TRPRINT,PRSI
	RSTACK	


	.FUNCT	PART-OF:ANY:0:0
	PRINT	YOU-CANT
	PRINTI	"--"
	ICALL2	IS-ARE-PRINT,PRSO
	PRINTI	"an integral part of"
	LOC	PRSO
	CALL2	TRPRINT,STACK
	RSTACK	


	.FUNCT	RECOGNIZE:ANY:0:0
	SET	'P-WON,FALSE-VALUE
	PRINTR	"[Sorry, but I don't understand. Please rephrase that or try something else.]"


	.FUNCT	PRONOUN:ANY:0:0
	EQUAL?	PRSO,ME \?CCL3
	PRINTI	"You"
	RTRUE	
?CCL3:	EQUAL?	PRSO,WHITE-CASTLE \?CCL5
	CALL	NOUN-USED?,WHITE-CASTLE,W?MAN
	ZERO?	STACK \?CCL5
	PRINTI	"It"
	RTRUE	
?CCL5:	FSET?	PRSO,PLURALBIT \?CCL9
	PRINTI	"They"
	RTRUE	
?CCL9:	FSET?	PRSO,FEMALEBIT \?CCL11
	PRINTI	"She"
	RTRUE	
?CCL11:	FSET?	PRSO,ACTORBIT \?CCL13
	PRINTI	"He"
	RTRUE	
?CCL13:	PRINTI	"It"
	RTRUE	


	.FUNCT	HIT-ANY-KEY:ANY:0:1,STRING
	PRINTI	"[Hit any key to "
	ZERO?	STRING /?CCL3
	PRINTI	"begin playing "
	PRINT	STRING
	JUMP	?CND1
?CCL3:	PRINTI	"continue"
?CND1:	PRINTI	".]"
	DIROUT	D-SCREEN-OFF
	CRLF	
	DIROUT	D-SCREEN-ON
	ZERO?	DEMO-VERSION? /?CCL6
	ICALL2	INPUT-DEMO,1
	JUMP	?CND4
?CCL6:	INPUT	1
?CND4:	CALL1	MOUSE-INPUT?
	RSTACK	


	.FUNCT	LOCKED-UNLOCKED:ANY:1:2,OBJ,UN
	PRINTI	"A faint click indicates that"
	ICALL2	TPRINT,OBJ
	PRINTI	" is now "
	ZERO?	UN /?CND1
	PRINTI	"un"
?CND1:	PRINTR	"locked."


	.FUNCT	CANT-TURN:ANY:1:1,STRING
	PRINT	YOU-CANT
	PRINTI	"turn that o"
	PRINT	STRING
	PRINT	PERIOD-CR
	RTRUE	


	.FUNCT	YOU-MUST-TELL-ME:ANY:0:0
	PRINTI	"You must tell me how to do that to"
	CALL2	ARPRINT,PRSO
	RSTACK	


	.FUNCT	GRUE-PIT-WARNING:ANY:0:0
	IN?	PROTAGONIST,DB /?CND1
	ZERO?	TIME-STOPPED \?CND1
	EQUAL?	HERE,PIT-BOMB-LOC /?CND1
	PRINTI	" You are likely to "
	FSET?	LANTERN,TRYTAKEBIT \?CCL8
	PRINTR	"fall into a bottomless pit."
?CCL8:	PRINTR	"be eaten by a grue."
?CND1:	CRLF	
	RTRUE	


	.FUNCT	DARK-DEATH:ANY:0:0
	PRINTI	"Oh, no! You have "
	FSET?	LANTERN,TRYTAKEBIT \?CCL3
	PRINTI	"fallen into a bottomless pit"
	JUMP	?CND1
?CCL3:	PRINTI	"walked into the slavering fangs of a lurking grue"
?CND1:	CALL2	JIGS-UP,STR?136
	RSTACK	

	.ENDSEG

	.ENDI
