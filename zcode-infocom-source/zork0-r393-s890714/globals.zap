	RSTACK	


	.FUNCT	ARCH-F:ANY:0:0
	EQUAL?	PRSA,V?ENTER \FALSE
	CALL1	V-WALK-AROUND
	RSTACK	


	.FUNCT	WINDOW-F:ANY:0:0
	EQUAL?	PRSA,V?LOOK-INSIDE \?CCL3
	EQUAL?	HERE,DIMWITS-ROOM,BASTION,SOLAR \?CCL6
	PRINTR	"The window offers a splendid view of the castle grounds."
?CCL6:	EQUAL?	HERE,FR-PENTHOUSE,OFFICES-NORTH,OFFICES-SOUTH /?CTR7
	EQUAL?	HERE,OFFICES-EAST,OFFICES-WEST \?CCL8
?CTR7:	EQUAL?	HERE,FR-PENTHOUSE /?CTR12
	GRTR?	FLOOR-NUMBER,20 \?CCL13
?CTR12:	PRINT	STR?132
	PRINTR	"; the air is pretty smoggy today."
?CCL13:	PRINTR	"The window offers a good view of Flatheadia."
?CCL8:	PRINTR	"Bug 29."
?CCL3:	EQUAL?	PRSA,V?CLOSE,V?OPEN \?CCL17
	EQUAL?	HERE,DIMWITS-ROOM,BASTION,SOLAR \?CCL20
	PRINTR	"The window is just a narrow slit in the stone wall; there's no way to open or close it."
?CCL20:	PRINTR	"The window is unopenable."
?CCL17:	EQUAL?	PRSA,V?LEAP-OFF,V?EXIT,V?ENTER \?CCL22
	EQUAL?	HERE,DIMWITS-ROOM,BASTION,SOLAR \?CCL25
	PRINTR	"These slitted windows are narrower than your body."
?CCL25:	CALL	DO-FIRST,STR?142,WINDOW
	RSTACK	
?CCL22:	EQUAL?	PRSA,V?PUT-THROUGH \FALSE
	EQUAL?	HERE,HOTHOUSE,DIMWITS-ROOM,SOLAR /?CTR29
	EQUAL?	HERE,BASTION \?CCL30
?CTR29:	REMOVE	PRSO
	PRINT	STR?205
	ICALL1	TPRINT-PRSO
	PRINTI	" sinks into the "
	EQUAL?	HERE,HOTHOUSE \?CCL35
	EQUAL?	PRSO,PERCH /?CCL37
	CALL	ULTIMATELY-IN?,PERCH,PRSO
	ZERO?	STACK /?CND36
?CCL37:	SET	'REMOVED-PERCH-LOC,WATER
?CND36:	PRINTI	"swamp outside"
	JUMP	?CND33
?CCL35:	EQUAL?	PRSO,PERCH /?CCL41
	CALL	ULTIMATELY-IN?,PERCH,PRSO
	ZERO?	STACK /?CND40
?CCL41:	SET	'REMOVED-PERCH-LOC,GROUND
?CND40:	PRINTI	"ground far below"
?CND33:	PRINT	PERIOD-CR
	RTRUE	
?CCL30:	CALL	DO-FIRST,STR?142,WINDOW
	RSTACK	


	.FUNCT	LOCK-OBJECT-F:ANY:0:0
