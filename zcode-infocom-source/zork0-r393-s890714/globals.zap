	RSTACK	


	.FUNCT	STAIRS-F:ANY:0:0
	EQUAL?	HERE,NORTH-SHORE,EAST-SHORE,SOUTH-SHORE /?PRD5
	EQUAL?	HERE,WEST-SHORE \?CCL3
