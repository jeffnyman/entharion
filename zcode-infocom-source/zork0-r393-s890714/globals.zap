	RTRUE	


	.FUNCT	GLOBAL-BLDG-F:ANY:0:0
	EQUAL?	PRSA,V?ENTER \?CCL3
	EQUAL?	HERE,FISHING-VILLAGE,WHARF \?CCL3
	CALL2	DO-WALK,P?NORTH
	RSTACK	
