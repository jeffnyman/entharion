	.FUNCT	WALL-F:ANY:0:0,CNT
	EQUAL?	PRSA,V?EXAMINE,V?READ \?CCL3
	EQUAL?	HERE,CHURCH \FALSE
	ICALL	PERFORM,V?READ,TENET
	RTRUE	
?CCL3:	EQUAL?	PRSA,V?CLEAN \?CCL8
	EQUAL?	HERE,CELL \?CCL8
	CALL	ADJ-USED?,WALL,W?REAR
	ZERO?	STACK /?CCL8
	IN?	COBWEBS,CELL \?CCL8
	ICALL	PERFORM,V?CLEAN,COBWEBS
	RTRUE	
?CCL8:	EQUAL?	PRSA,V?THROW-OVER \?CCL14
	PRINTR	"The wall joins the ceiling!"
?CCL14:	EQUAL?	PRSA,V?PUT-ON,V?PUT \FALSE
	EQUAL?	PRSO,NW-SE-PASSAGE,N-S-PASSAGE \FALSE
	CALL	ADJ-USED?,WALL,FALSE-VALUE
	ZERO?	STACK /?CCL22
	SET	'P-WON,FALSE-VALUE
	PRINTR	"[You didn't specify which wall you meant: EAST WALL for example.]"
?CCL22:	EQUAL?	PRSO,N-S-PASSAGE \?PRD26
	CALL	ADJ-USED?,WALL,W?NORTH,W?N
	ZERO?	STACK \?PRD26
	CALL	ADJ-USED?,WALL,W?SOUTH,W?S
	ZERO?	STACK /?CTR23
?PRD26:	EQUAL?	PRSO,NW-SE-PASSAGE \?CCL24
	CALL	ADJ-USED?,WALL,W?NORTHWEST,W?NW
	ZERO?	STACK \?CCL24
	CALL	ADJ-USED?,WALL,W?SOUTHEAST,W?SE
	ZERO?	STACK \?CCL24
?CTR23:	PRINT	YOU-CANT
	PRINTI	"install the passage on that wall--it's"
	CALL2	ARPRINT,PRSO
	RSTACK	
?CCL24:	CALL1	PASSAGE-THERE
	ZERO?	STACK \TRUE
	EQUAL?	HERE,GONDOLA,HOLD /?CTR35
	LOC	PROTAGONIST
	EQUAL?	STACK,YACHT,DB \?CCL36
?CTR35:	PRINTR	"A built-in safety feature prevents the passage from being installed in a vehicle."
?CCL36:	MOVE	PRSO,HERE
	FCLEAR	PRSO,TAKEBIT
	SET	'COMPASS-CHANGED,TRUE-VALUE
	PUTP	PRSO,P?OWNER,WALL
	PRINTI	"There's now a passage leading "
	EQUAL?	PRSO,N-S-PASSAGE \?CCL41
	EQUAL?	HERE,CONSTRUCTION \?CND42
	SET	'N-S-PASSAGE-LOC,CONSTRUCTION-LOC
?CND42:	CALL	ADJ-USED?,WALL,W?NORTH,W?N
	ZERO?	STACK /?CCL46
	SET	'N-S-PASSAGE-DIR,P?NORTH
	EQUAL?	HERE,CONSTRUCTION \?CND47
	LESS?	CONSTRUCTION-LOC,8 /?CND47
	ADD	CONSTRUCTION-LOC,100
	PUT	NORTH-EXITS,0,STACK
?PRG51:	GET	STORAGE-TABLE,CNT
	ZERO?	STACK \?CCL55
	SUB	CONSTRUCTION-LOC,8
	ADD	STACK,CONSTRUCTION-OFFSET
	PUT	STORAGE-TABLE,CNT,STACK
	ADD	CNT,1
	PUT	STORAGE-TABLE,STACK,N-S-PASSAGE
?CND47:	PRINTI	"nor"
	JUMP	?CND44
?CCL55:	ADD	CNT,2 >CNT
	JUMP	?PRG51
?CCL46:	SET	'N-S-PASSAGE-DIR,P?SOUTH
	EQUAL?	HERE,CONSTRUCTION \?CND56
	GRTR?	CONSTRUCTION-LOC,55 /?CND56
	ADD	CONSTRUCTION-LOC,108
	PUT	NORTH-EXITS,0,STACK
?PRG60:	GET	STORAGE-TABLE,CNT
	ZERO?	STACK \?CCL64
	ADD	CONSTRUCTION-LOC,8
	ADD	STACK,CONSTRUCTION-OFFSET
	PUT	STORAGE-TABLE,CNT,STACK
	ADD	CNT,1
	PUT	STORAGE-TABLE,STACK,N-S-PASSAGE
?CND56:	PRINTI	"sou"
?CND44:	PRINTR	"th from the room."
?CCL64:	ADD	CNT,2 >CNT
	JUMP	?PRG60
?CCL41:	EQUAL?	HERE,CONSTRUCTION \?CND65
	SET	'NW-SE-PASSAGE-LOC,CONSTRUCTION-LOC
?CND65:	CALL	ADJ-USED?,WALL,W?NORTHWEST,W?NW
	ZERO?	STACK /?CCL69
	SET	'NW-SE-PASSAGE-DIR,P?NW
	EQUAL?	HERE,CONSTRUCTION \?CND70
	MOD	CONSTRUCTION-LOC,8
	ZERO?	STACK /?CND70
	LESS?	CONSTRUCTION-LOC,8 /?CND70
	ADD	CONSTRUCTION-LOC,91
	PUT	SE-EXITS,0,STACK
?PRG76:	GET	STORAGE-TABLE,CNT
	ZERO?	STACK \?CCL80
	SUB	CONSTRUCTION-LOC,9
	ADD	STACK,CONSTRUCTION-OFFSET
	PUT	STORAGE-TABLE,CNT,STACK
	ADD	CNT,1
	PUT	STORAGE-TABLE,STACK,NW-SE-PASSAGE
?CND70:	PRINTI	"northwe"
	JUMP	?CND67
?CCL80:	ADD	CNT,2 >CNT
	JUMP	?PRG76
?CCL69:	SET	'NW-SE-PASSAGE-DIR,P?SE
	EQUAL?	HERE,CONSTRUCTION \?CND81
	MOD	CONSTRUCTION-LOC,8
	EQUAL?	STACK,7 /?CND81
	GRTR?	CONSTRUCTION-LOC,55 /?CND81
	ADD	CONSTRUCTION-LOC,100
	PUT	SE-EXITS,0,STACK
?PRG87:	GET	STORAGE-TABLE,CNT
	ZERO?	STACK \?CCL91
	ADD	CONSTRUCTION-LOC,9
	ADD	STACK,CONSTRUCTION-OFFSET
	PUT	STORAGE-TABLE,CNT,STACK
	ADD	CNT,1
	PUT	STORAGE-TABLE,STACK,NW-SE-PASSAGE
?CND81:	PRINTI	"southea"
?CND67:	PRINTR	"st from the room."
?CCL91:	ADD	CNT,2 >CNT
	JUMP	?PRG87


	.FUNCT	PASSAGE-THERE:ANY:0:0,PASSAGE?
	CALL	ADJ-USED?,WALL,W?NORTH,W?N
	ZERO?	STACK /?CCL3
	EQUAL?	HERE,PEG-ROOM \?CCL6
	ZERO?	PEG-PASSAGE-OPENED \?CCL9
	ICALL2	REPELLED,STR?203
	SET	'PASSAGE?,M-FATAL
	JUMP	?CND1
?CCL9:	SET	'PASSAGE?,FALSE-VALUE
	JUMP	?CND1
?CCL6:	EQUAL?	HERE,SECRET-PASSAGE \?CCL11
	ZERO?	SECRET-PASSAGE-OPEN \?CCL14
	ICALL2	REPELLED,STR?203
	SET	'PASSAGE?,M-FATAL
	JUMP	?CND1
?CCL14:	SET	'PASSAGE?,FALSE-VALUE
	JUMP	?CND1
?CCL11:	EQUAL?	HERE,CONSTRUCTION \?CCL16
	INTBL?	NORTH-EXITS,CONSTRUCTION-LOC,11 \?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL16:	EQUAL?	HERE,WEIRD \?CCL20
	EQUAL?	TOWER-BEATEN,PYRAMID /?CCL20
	ICALL2	REPELLED,STR?203
	SET	'PASSAGE?,M-FATAL
	JUMP	?CND1
?CCL20:	EQUAL?	HERE,G-U-MOUNTAIN \?CCL24
	IN?	BOULDER,HERE \?CCL27
	ICALL2	REPELLED,STR?203
	SET	'PASSAGE?,M-FATAL
	JUMP	?CND1
?CCL27:	SET	'PASSAGE?,FALSE-VALUE
	JUMP	?CND1
?CCL24:	GETPT	HERE,P?NORTH
	ZERO?	STACK /?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL3:	CALL	ADJ-USED?,WALL,W?SOUTH,W?S
	ZERO?	STACK /?CCL30
	EQUAL?	HERE,CONSTRUCTION \?CCL33
	ADD	CONSTRUCTION-LOC,8
	INTBL?	NORTH-EXITS,STACK,11 \?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL33:	EQUAL?	HERE,THRONE-ROOM \?CCL37
	ZERO?	SECRET-PASSAGE-OPEN \?CCL40
	ICALL2	REPELLED,STR?204
	SET	'PASSAGE?,M-FATAL
	JUMP	?CND1
?CCL40:	SET	'PASSAGE?,FALSE-VALUE
	JUMP	?CND1
?CCL37:	GETPT	HERE,P?SOUTH
	ZERO?	STACK /?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL30:	CALL	ADJ-USED?,WALL,W?NORTHWEST,W?NW
	ZERO?	STACK /?CCL43
	EQUAL?	HERE,CONSTRUCTION \?CCL46
	SUB	CONSTRUCTION-LOC,9
	INTBL?	SE-EXITS,STACK,7 \?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL46:	EQUAL?	HERE,PERIMETER-WALL \?CCL50
	SET	'PASSAGE?,FALSE-VALUE
	JUMP	?CND1
?CCL50:	GETPT	HERE,P?NW
	ZERO?	STACK /?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL43:	CALL	ADJ-USED?,WALL,W?SOUTHEAST,W?SE
	ZERO?	STACK /?CND1
	EQUAL?	HERE,CONSTRUCTION \?CCL55
	INTBL?	SE-EXITS,CONSTRUCTION-LOC,7 \?CND1
	SET	'PASSAGE?,TRUE-VALUE
	JUMP	?CND1
?CCL55:	GETPT	HERE,P?SE
	ZERO?	STACK /?CND1
	SET	'PASSAGE?,TRUE-VALUE
?CND1:	EQUAL?	PASSAGE?,M-FATAL /TRUE
	ZERO?	PASSAGE? /FALSE
	PRINTR	"There's already an exit in that direction!"


	.FUNCT	REPELLED:ANY:1:1,STRING
	PRINTI	"Strangely, the passage seems repelled by the "
	PRINT	STRING
	PRINTR	" wall, as though two inconsistent types of magic were at work in the same place."


