	CALL1	IMPOSSIBLES
	RSTACK	
?CCL12:	EQUAL?	PRSA,V?CLIMB,V?CLIMB-ON,V?CLIMB-UP /?CTR13
	EQUAL?	PRSA,V?ENTER \?CCL14
?CTR13:	CALL1	WASTES
	RSTACK	
?CCL14:	EQUAL?	PRSA,V?LEAVE \FALSE
	CALL2	DO-WALK,P?UP
	RSTACK	


