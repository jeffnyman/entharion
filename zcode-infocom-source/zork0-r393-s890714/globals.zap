?CCL12:	EQUAL?	PRSA,V?PUT-ON,V?PUT \FALSE
	EQUAL?	PRSI,GLOBAL-HERE \FALSE
	EQUAL?	P-PRSA-WORD,W?THROW \?CCL19
	ICALL	PERFORM,V?THROW,PRSO
	RTRUE	
