PartyRoom second_bedroom "In a Bedroom with Two Mysterious Girls"
 with 	description
	[;
	    print "Well, this isn't as cool as you had hoped this 
		kind of thing would be. The bed's been pushed to one 
		side of the room, presumably to make more room for 
		some kind of insane board game that's being played 
		on a ridiculous number of tables, each of which is 
		set up in some obviously important position. There 
		are weird little tiles all over them.^^As previously 
		advertised, there are two girls kneeling beside the 
		tables, planning out some kind of strategy. ";

	    if (self hasnt visited)
	    	print "They look briefly up at you, but it's clear
		    that their priorities are elsewhere. ";

	    print "The music thrums loudly below you, but
		the girls don't seem to care";

	    if (self hasnt visited)
		print " about that, either";

	    SetPronoun('them', second_bedroom_girls);
	    SetPronoun('her', second_bedroom_girls);
	    ".^^To the south is the hallway.";
	],
	s_to second_hallway_end;

Object 	-> second_bedroom_bed "bed"
 with 	name
	    'bed' 'mattress' 'sheet' 'sheets',
	description
