!
! Blue Chairs
! the initial party
!

!
! Before the opening
!

Object 	pre_attic "Stuck in an Attic"
 with 	description
	[;
	    SetPronoun('him', pre_attic_dude);
	    "Sure, you're used to piece-of-shit architecture (you
	    live in Dundalk, for crissake), but this place will be
	    receiving some kind of award from you by the end of the
	    night. There's totally unimportant crap strewn all over
	    the place -- old sewing machines, an Easy-Bake oven,
	    even a set of folding chairs painted carnival blue --
	    but fortunately, almost all of it is in shadow thanks to
	    an underperforming fifty-watt bulb directly above.^^It's
	    just you and the dude here. The only place in the entire
	    house you could get any privacy. It's only ten o'clock
	    and already the call to hook up has come down from the
	    heavens.^^Stairs lead downward, back to the party and
	    that awful trance-bop they keep playing.";
	],
	before
	[;
	 Yes:
	    <<Take drug_bottle>>;
	    
	 No:
	    <<Go d_obj>>;
	],
	cant_go
	    "There's nowhere to go from here but down.",
	d_to
	[;
	    if (self hasnt general)
	    {
		give self general;
		"Now technically speaking, you have a great deal of
		free will during this story, so you're allowed to
		call it a night here and now.^^You can go ahead and
		go downstairs if you want to -- surely there's
		something interesting going on in this party. Maybe
		there's a pretty girl with long blonde hair you bump
		into and end up hooking up with. You won't remember
		whether her name is Alice or Alicia, so you'll bail
		the next morning without a word.^^It's okay. You
		won't see her ever again. And it all happens again
		the next weekend, and the weekend after that,
		too.^^So it's okay if you want to say no to the
		whole thing.";
	    }
	    else
	    {
		deadflag = DEAD_CUBICLE;
		"It's not worth it, you decide. So you say a quick
		goodbye, thanks anyway, whatever, and head down the
		stairs straight into a story that was never meant
		for you.";
	    };
	];

Object 	-> pre_attic_bulb "fifty-watt bulb"
 with 	name
	    'bulb' 'light' 'lights' 'fifty-watt' 'fifty' 'watt',
	description
	    "Probably installed a hundred years ago. In this sense,
	    it's a credit to Thomas Edison or General Electric or
	    whoever was in charge of light bulbs back then. It is
	    otherwise pretty uninteresting, even on the light bulb
	    scale of interest.",
	before
	[;
	 Take:
	    "The light bulb's not going anywhere. Seriously.";
	    
	 SwitchOn:
	    "Although you may have missed it, the light is already 
	    on.";

	 SwitchOff:
	    "As hip/urban/postmodern as you are, You're not really 
	    comfortable with the concept of being in a dark room 
	    with this skeeve.";
	],
 has 	scenery;

Object -> pre_attic_sewing_machines "sewing machines"
 with 	name
	    'sewing' 'machines' 'machine',
	before
	[;
	    "Now if you investigated really carefully, you'd find 
	    that hidden inside one of those sewing machines is a 
	    treasure map to a lost underground empire beneath this 
	    very house. And by the time this story ended, you'd have 
	    a couple dead trolls and a shitload of ancient treasures 
	    to your name -- but who wants to tell their grandkids a 
	    life story that begins with you screwing around with 
	    some sewing machines in the middle of a drug deal?^^So 
	    leave the sewing machines alone, okay?";
	],
 has 	scenery;

Object 	-> pre_attic_oven "Easy-Bake oven"
 with 	name
	    'easy' 'bake' 'easy-bake' 'oven',
	before
	[;
	    print "Here's a secret: if you open the Easy-Bake oven's
		door, you'll find a portal leading to a fantastical
		land full of figures from classical mythology (we'll
		even throw in a reference to ";
	    style underline;
	    print "Snow Crash";
	    style roman;
	    ", since you've probably read it as well). The whole
	    adventure will turn out to be either a profound
	    self-examination or a mindless romp littered with
	    fucked-up puzzles -- either way, you're going to end up
	    seriously disappointed.^^Have a little faith in authorial
	    intent and leave the Easy-Bake oven alone, okay?";
	],
 has 	scenery;

Object 	-> pre_attic_chairs "blue chairs"
 with 	name
	    'carnival' 'blue' 'folding' 'chair' 'chairs',
	before
	[;
	    "The blue chairs are bad news. Best just to leave them
	    alone.";
	],
 has 	scenery;

Object 	-> pre_attic_dude "guy"
 with 	parse_name
	[ i definite_match;

	    while (true)
		switch (NextWord())
		{
		 'guy', 'man', 'dude', 'christopher', 'chris',
		 'klimas', 'dealer':
		    definite_match = true;
		    i++;
		    
		 'drug':
		    i++;

		 default:
		    if (definite_match)
			return i;
		    else
			return 0;
		};
	],
	description
	    "In middle school, he would've been the kind of kid you
	    would have written off immediately. Greasy hair and a
	    dirty look in his eyes, like he's simultaneously thinking
	    of fucking some cheerleader's brains out and calculating
   	    how many experience points a red dragon is worth.^^The
	    problem is that this is the real world, such as it is, and
	    he's still the the same greasy kid. But then again, you're
	    still the same loser you've always been at heart.",
	life
	[;
	 Tell, Answer:
	    "You don't feel like getting expository on this dweeb.";

	 Kiss:
	    "Please.";

	 Attack:
	    "Not a half-bad strategy, but it's early still to get
	    violent.";

	 Give:
	    if (noun == money)
	    {
		remove money;
		Title();
		rtrue;
	    };

	 Show:
	    if (noun == money)
	    	"~So I take it you want to buy?~ the guy says.";
	    else
		"He looks kind of unimpressed.";
	    
	 Ask:
	    switch (second)
	    {
	     'drug', 'drugs', 'medicine', 'bottle', 'cough', 'syrup',
	     'green', 'stuff':
		"~What is that stuff going to do to me?~ you
		ask.^^~In the long run, probably kill you,~ he says,
		putting on a dungeonmaster grin. ~Short term, life
		gets pretty fucking grand.~ Coming from a real drug
		dealer, it would give you pause. But let's face facts:
		this dweeb probably just put some food coloring into
		some DXM and called it a day.";

	     'deal', 'offer', 'money', 'dollars', 'twenty-three',
	     'twenty', 'three':
		"~Why twenty-three dollars?~ you ask.^^~You look like
		the kind of man who can pay that kind of price,~ he
		says a little peevishly -- probably expecting you to
		try some kind of haggling maneuver.";

	     'himself', 'him', 'guy', 'dude', 'man', 'chris',
	     'christopher', 'klimas':
		self.told_name = true;
		"~What's your name, anyway?~ you ask.^^~Chris,
		why?~^^~Dunno, just seemed like a useful thing to
		know.~";

	     'house', 'attic':
		"~What a piece of shit house, eh?~ you
		comment.^^~There are worse places to be,~ the guy
		says, trying his best to put on a worldly air, like
		he's mentally comparing it Tangiers or something.";

	     'party', 'music', 'tonight', 'here':
		"~What do you think of this party?~ you ask.^^He just
		shrugs. ~Where you gotta be, you gotta be.~";
		
	     default:
		"You engage in some useless small talk with the
		guy. He smiles and nods just like anybody else, but
		it's clear he doesn't really care.";
	    };
	],
	react_before
	[;
	 Take, Drink:
	    if ((noun == drug_bottle) && (drug_bottle in self))
		"~Not so fast,~ the guy says. ~You need to give me 
		some actual cash here.~";
	 Buy:
	    if ((noun == drug_bottle) && (drug_bottle in self))
	    {
		if (money in player)
		{
		    print "(giving your money to the guy)^";
		    Title();
		    rtrue;
		}
		else
		    "~Can I see some cash here?~ the guy asks.";
	    };
	],
	before
	[;
	 Taste:
	    <<Kiss self>>;
	],
	orders
	[;
	 Yes:
	    <<buy drug_bottle>>;

	 No:
	    <<Go d_obj>>;

	 default:
	    "The guy looks at you, unconvinced.";
	],
	each_turn
	[;
	    self.number++;
	    
	    if (self.number == 3 or 6 or 9)
		"^The guy waggles the bottle a little in case your
		attention is wandering.";

	    if (self.number == 12)
		"^~Hey, are you going to buy this shit or what?~ the
		guy asks. ~Cause there are about twenty-three other
		people I'd rather be talking to right now.~";
	],
	number 0,
	told_name false,
 has 	animate male concealed transparent;

Object 	-> -> drug_bottle "cough syrup bottle"
 with 	parse_name
	[ i;
 	    while (true)
 		switch (NextWord())
		{
		 'medicine', 'bottle', 'cough', 'syrup', 'drug',
		 'drugs':
		    i++;
		    
	         'green', 'liquid':
		    if (green_drugs in self)
			i++;
		    else
			return i;

		 default:
		    return i;
		};
	    ],
	description
	[;
	    print "The label on the side of the bottle reads:
		PHOLCODINE 5 mg. Mm-hmm. ";
	    
	    if (green_drugs in self)
		"The actual liquid looks kind of weird. It's maybe
		close to the color of creme de menthe (ah, college
		days, where mixed drinks were new and exciting) but
		paler.";
	    else
		"Right now it's empty.";
	],
	before
	[;
	 Search:
	    if (green_drugs in self)
		<<Examine self>>;
	    else
		"Right now, it's empty.";

	 Receive:
	    "You don't see what that would accomplish.";
	];

Object 	-> -> -> green_drugs;

!
! Post-intro attic
!

Class 	PartyRoom
 with 	each_turn
	[;
	    if (random(4) == 1)
		switch (random(11))
		{
		 1, 2:
		    "^There's a crash somewhere else in the house --
		    you can't tell where, exactly -- followed by a
		    happy shout.";

		 3:
		    print "^You hear someone running ";
		    if (self ~= post_attic)
			print "upstairs";
		    else
			print "downstairs";
		    " -- scampering, almost.";
		    
		 5, 6, 7, 8:
		   "^You lose your balance momentarily -- weird. You
		    don't feel intoxicated, exactly, not yet...";

		 9:
		    "^You hear someone cackling hysterically -- not
		    sure what direction it's coming from, though.";

		 10:
		    "^For a moment, there's a weird odor, like
		    someone's lit a candle. But then it's gone.";

		 11:
		    "^There's silence for a second, and then the music
		    cuts back on.";
		};
	];

Class PartyObject
 with found_in
	[;
	    return (location ofclass PartyRoom);
	];

PartyObject party_music "music"
 with 	name
	    'music' 'noise',
	description
	    "Kind of hard to see the music, per se.",
	before
	[;
	 Listen:
	    "It's hard to follow just one thread of it; you keep
	    losing track of it, like voices in a bar.";
	],
 has 	scenery;

PartyRoom post_attic
 with 	short_name
	[;
	    if (self has general)
		print "Not Exactly the Same Attic";
	    else
		print "In the Dark and Noise of an Attic";

	    rtrue;
	],
	description
	[;
	    if (self has general)
	    	"It's the light that makes it different: somehow
		it's become even dimmer than before, so that
		everything is shadow but your own body and the
		stairs leading down. Who knows what's in the
		recesses of the dark? Probably plenty of useful
		things: things to keep your shoelaces tied, things
		to remind you of your dentist appointments -- even
		things that could save your own life. But who knows?
		It's just a pile of stuff you don't know how to sort
		through.^^The music downstairs is insistent, even
		burning.";
	    else
		"You can't see a thing but it doesn't matter because
		the music fills in what isn't there. There may be
		monsters all around you -- the whole place smells
		like nearly-rotting pumpkins or maybe your
		grandmother's last meal -- but it doesn't matter
		because you aren't scared.";
	],
	d_to second_landing,
 has 	general;

Object 	-> post_attic_bulb "light bulb"
 with 	name
	    'bulb' 'light' 'lights' 'fifty-watt' 'fifty' 'watt',
	description
	    "It's just the same light bulb it was before.",
	after
	[;
	 SwitchOn:
	    give post_attic general;
	    <<Look>>;

	 SwitchOff:
	    give post_attic ~general;
	    <<Look>>;
	],
	before
	[;
	 Take:
	    "You don't see any point in taking it.";
	],
 has 	scenery switchable on;

Object 	-> post_attic_darkness "darkness"
 with 	name
	    'darkness' 'dark' 'shadow' 'recesses' 'recess' 'pile' 'of'
	    'stuff' 'useful' 'things' 'attic',
	description
	[;
	    if (ContainsLight(player))
	    {
		if (wine_bottle in self)
		{
		    move wine_bottle to parent(self);
		    "Armed with a flashlight, it's a lot easier to 
		    sort through all this junk and detritus... you 
		    wonder who it belongs to, since Rob, the guy 
		    renting this place, probably doesn't have a lot 
		    of use for an artillery manual or a sky blue 
		    wig... what's this?^^There's a bottle of wine 
		    hidden here. Only it's not normal wine.";
		}
		else
		    "Come on, man, you were lucky enough with that 
		    wine bottle. Don't get greedy.";
	    }
	    else
	    {
	    	if (post_attic hasnt general)
		    "You grope around in the dark, but you don't find
		    anything tangible.";

	    	print "You rummage through a pile of ";
	    	print (string) random("empty Atari 2600 game boxes", "old
				      tax returns", "postcards from
				      Spain", "coloring books",
				      "dessicated comic books");
	    	print "... ";
	    	print (string) random("a half-strung tennis racket", "a
				      set of Lucky Charms-themed playing
				      cards", "a broken marionette", "an
				      acid green sweater", "some kind of
				      machine that looks like it
				      develops photographs");
	    	print "... ";
	    	print (string) random("a teddybear with no eyes left", "a
				      red marker", "someone's philosophy
				      homework from 1976", "a Beatles
				      record", "a nearly-empty bag of dog
				      food");
	    	"... nothing useful.";
	    };
	],
	before
	[;
	 Search:
	    <<Examine self>>;

	 Enter:
	    "There's too much stuff to just wade through.";
	],
 has 	scenery;

Object 	-> -> wine_bottle "wine bottle"
 with 	name
	    'bottle' 'wine' 'gold' 'yellow' 'orange',
	description
	[;
	    if (~~ player.drank_wine)
	    {
		print (The) self, "'s ordinary enough, but the stuff 
		    inside is fucking orange. Like pumpkin orange.";
		
		if ((self in player) && (self hasnt general))
		{
		    give self general;
		    print " You give it an exploratory shake -- there
			are these little reddish streaks in it that
			shift slightly.";
		};

		" There's no label on it. Maybe it's actually some
		kind of pasta sauce? Either way, Mom would definitely
		not approve.";
	    }
	    else
	    	print_ret (The) self, "'s still maybe three-quarters 
		    full of that weird orange liquid.";
	],
	before
	[;	    
	 Drink:
	    if (player.drank_wine)
		"Honestly, you're happy with where your relationship 
		is with this wine right now. More would probably be 
		pushing it.";
	    else
	    {
		player.drank_wine = true;
		if (player.beers)
		{
		    style underline;
		    print "Beer in Fridge vs. Strange Orange Wine: A
			Study in Contrasts";
		    style roman;
		    print " by Dante Hicks: ";
		}

		print "Sure, the wine tastes like it should've been 
		    drunk about five centuries ago, and honestly it 
		    really does taste like pumpkin juice, or what 
		    pumpkin juice would taste like if there were 
		    such a thing. But it's got character. And more 
		    importantly, it makes you feel different and 
		    pleasant. The stuff is obviously potent, but 
		    somehow it doesn't feel like you're going to get 
		    trashed.";

		if (player.beers)
		    print " It's fundamentally different from the 
			beer in that respect. In fact, it almost 
			erases the beer from your memory.";

		"^^It makes you feel like life is being nicely 
		chilled before being served to you. It also makes 
		you want to dance.";
	    };

	 Empty:
	    "Why waste it?";

	 Close:
	    if (self has open)
		"There's no obvious way to close the wine bottle again.";

	 ThrowAt:
	    "That doesn't seem like a very cool thing to do.";
	],
	after
	[;
	 Open:
	    give self open;
	    "The cork is loose for some reason; it comes off with a
	    shallow sort of pop.";
	],
 has 	openable;


!
! Second floor
!

PartyRoom second_landing "Second Floor Landing"
 with 	description
	[;
	    print "Christmas lights twist around the railing leading 
		down. There are enough of them that the the walls of 
		the stairway are the hue of fruit salad, the kind 
		with tiny oranges, not the other kind, the kind with 
		apple slices. Ugh. That awful shade of brown they 
		turn once they're exposed to air for too long.";

	    if (self hasnt general)
	    {
		give self general;
		print "^^The music's louder now, and there are 
		    echoes of synthesizer burble and cymbal crashes. 
		    It's starting to make sense in your 
		    head.";
	    };
	    
	    "^^Stairs go up and down, and there's a hallway to the 
	    west.";
	],
	w_to second_hallway,
	u_to post_attic,
	d_to foyer;

Object 	-> second_landing_lights "Christmas lights"
 with 	name
	    'lights' 'light' 'christmas' 'xmas',
	description
	    "Just typical college-student decor. Which is of course
	    is a little odd, seeing as how the people throwing the
	    party -- friends of a friend -- are at least four years
	    out of UMBC. Old habits die hard.",
	before
	[;
	 Take:
	    "No time for interior redesign.";
	],
 has 	scenery pluralname;

Object 	-> second_landing_railing "railing"
 with 	name
	    'railing',
	description
	    "The railing's bare black metal.",
 has 	scenery;

PartyRoom second_hallway "A Short Hallway"
 with 	description
	[;
   	    print  "It's a regular old hallway with blank off-white 
		walls. Undoubtedly you'll forget all about this one 
		in a couple days -- isn't that sort of sad? Then 
		again, it's just a hallway, one of thousands, one of 
		millions of moments your brain will eventually 
		discard as unimportant.^^There's a door north ";
	    
	    if (second_bathroom hasnt visited)
    		print "-- you think it's to a bathroom --";
	    else
		print "that leads to a bathroom;";
	    
	    " the hallway continues west, and the landing is back to 
	    the east.";
	],
	e_to second_landing,
	w_to second_hallway_end,
	n_to second_hallway_door;

! There's some trickery here with the describe property because
! concealed doors don't work right.

Object -> second_hallway_door "bathroom door"
 with 	parse_name
	[ i;
	    while (true)
		switch (NextWord())
		{
		 'bathroom', 'north', 'door':
		    i++;

		 'smidge', 'crack', 'in', 'the':
		    if (second_hallway_voice notin second_hallway)
			i++;
		    else
			return i;

		 default:
		    return i;
		};
	],
	describe
	[;
	    rtrue;
	],
	description
	[;
	    if (second_hallway_voice in second_hallway)
	    	"Just a plain, off-white door.";
	    else
		"The lights are on inside -- that's all you can tell
		from looking through the crack.";
	],
	before
	[;
	 Enter:
	    if (self hasnt open)
		"The door's locked.";
	   
	 Open:
	    if (second_hallway_voice notin parent(self))
	    {
		if (self has open)
		    <<Enter self>>;
		else
		    rfalse;
	    };
	    
	    switch (self.number)
	    {
	     1:
	       	self.number++;
	       	"It's locked.^^~Hey,~ a male voice calls from
		inside. ~I'm in here. Please don't bother me.~";
		
	     4:
	       	"It's locked again now. What the hell?";
		
	     default:
	       "It's locked.";
	    };
	    
	 Unlock:
	    if (second == silver_key)
		"The silver key doesn't fit the lock. Bleh.";
	    else
		<<Open self>>;
	    
	 Attack:
	    if (second_hallway_voice notin second_hallway)
	    	"There's no response.";

	    switch (self.number)
	    {
	     1:
		self.number++;
		"~It's just me in here,~ the voice says. ~I know I
		ought to have someone else in here that I'm making
		out with, but it's just me. Please don't knock on
		the door again or I'll have to tell you more.~";

	     2:
		self.number++;
		print "~Look,~ the voice says. ~I just want to be
		    left alone.~^^A pause, and then a quiet
		    question: ~Have you ever felt alone as me?~^^>>";

		if (YesOrNo())
		{
		    give self open;
		    remove second_hallway_voice;
		    "~Yeah,~ you say. ~Assuming of course you are 
		    not suffering from any--~^^~Do you make things 
		    up just like me?~ the voice asks. ~I think 
		    sometimes that I should believe in made-up 
		    things.~^^There's an audible crack: the door is 
		    open a smidge.";
		};
		
		"~No,~ you say. ~Probably not.~^^~But you will be,~
		the voice says. ~Someday.~";

	     3:
		"This time, there is no reply.";
	    };
	],
	door_dir n_to,
	door_to second_bathroom,
	number 1,
 has 	static door openable;

Object 	-> second_hallway_voice "voice"
 with 	name
	    'voice' 'guy' 'man' 'dude',
	description
	    "There's no really anything to see, owing to the closed
	    door.",
	before
	[;
	 AskForRide:
	    "~Hey, is there any chance you could give me a ride?~ you
	    ask weakly.^^There's a long silence.^^~No,~ the voice
	    says. ~It would be a bad idea.~";
	],
	life
	[;
	 WakeOther, Kiss, Attack:
	    "Huh?";
	    
	 Give, Show:
	    "Um, you're going to have to somehow get around that door
	    problem first.";

	 Ask:
	    "He doesn't reply.";
	    
	 Tell:
	    switch (second)
	    {
	     'myself', 'me':
		"~Hey, my name's Dante,~ you say.^^There isn't a
		reply.";

	     'beatrice':
		print "~Look, there's this girl Beatrice I know--~ you
		    begin.^^~Is she pretty?~ the voice asks.^^>>";
		if (YesOrNo())
		    "~Yeah, she kind of is,~ you say.^^~I thought she
		    would be,~ the voice says. ~I hope you find
		    her.~";
		else
		    "~Not exactly,~ you say. ~She's not ugly or
		    anything, but she never turned anyone's head...
		    but that's sort of part of why I--~^^~Please,~
		    the voice says. ~Please don't tell me any
		    more. I'm sorry for asking.~";

	     default:
		"You talk for a little bit, but the voice doesn't
		respond.";
	    };
	],
	orders
	    "The voice doesn't reply.",
 has 	scenery animate;

PartyRoom second_bathroom "An Empty Bathroom"
 with 	description
	    "What the fuck? There's nobody in here. There's nothing
	    in here. The fuck? Seriously. This is not cool.^^(To the
	    south is the hallway...)",
	before
	[;
	 Go:
	    if (noun == s_obj)
	    {
		give second_hallway_door ~open;
		second_hallway_door.number++;
		rfalse;
	    };
	],
	goto_next_room
	    "You're too flustered, too confused...",
	s_to second_bathroom_door;

